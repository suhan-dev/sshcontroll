permission_open_target() {
  local pane target label url expanded
  IFS= read -r pane || pane="fullDiskAccess"
  IFS= read -r target || target=""
  IFS= read -r label || label=""
  expanded="$(expand_remote_path "$target")"
  url="$(privacy_pane_url "$pane")"
  if [[ -z "$expanded" ]]; then
    printf 'Permission target path is empty.\n' >&2
    exit 64
  fi

  open "$url" >/dev/null 2>&1 || true
  if [[ -e "$expanded" ]]; then
    open -R "$expanded" >/dev/null 2>&1 || true
    if [[ -d "$expanded" && "$expanded" == *.app ]]; then
      open -a "$expanded" >/dev/null 2>&1 || true
    fi
  else
    printf 'Permission target not found: %s\n' "$expanded" >&2
  fi

  cat <<EOF
A permission target opened.
name: ${label:-$target}
pane: $pane
path: $expanded

On A, add or enable this target in the opened Privacy & Security pane.
macOS still requires the final approval click from the user.
EOF
}

