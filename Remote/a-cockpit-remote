battery_summary() {
  local battery_line ioreg_output percent state adapter cycle temp
  battery_line="$(pmset -g batt 2>/dev/null | awk 'NR == 2 { print }' || true)"
  ioreg_output="$(ioreg -r -c AppleSmartBattery -d 1 2>/dev/null || true)"
  percent="$(printf '%s\n' "$battery_line" | sed -n 's/.*[^0-9]\([0-9][0-9]*\)%;.*/\1/p')"
  state="$(printf '%s\n' "$battery_line" | sed -n 's/.*%; *\([^;]*\);.*/\1/p')"
  adapter="$(printf '%s\n' "$ioreg_output" | awk '
    /"AdapterDetails"/ && /"Watts"/ {
      watts=$0
      sub(/^.*"Watts"=/, "", watts)
      sub(/[^0-9].*$/, "", watts)
      if (watts != "") { print watts " W"; exit }
    }
  ')"
  cycle="$(printf '%s\n' "$ioreg_output" | awk -F'= ' '
    /^[[:space:]]+"CycleCount" =/ {
      gsub(/[ ;]/, "", $2)
      print $2
      exit
    }
  ')"
  temp="$(printf '%s\n' "$ioreg_output" | awk -F'= ' '
    /^[[:space:]]+"Temperature" =/ {
      gsub(/[ ;]/, "", $2)
      if ($2 ~ /^[0-9]+$/) {
        printf "%.1f C", $2 / 100.0
      }
      exit
    }
  ')"

  if [[ -n "$percent" ]]; then
    printf 'Battery: %s%%' "$percent"
    [[ -n "$state" ]] && printf ' · %s' "$state"
    [[ -n "$adapter" ]] && printf ' · %s' "$adapter"
    [[ -n "$temp" ]] && printf ' · temp %s' "$temp"
    [[ -n "$cycle" ]] && printf ' · cycles %s' "$cycle"
    printf '\n'
  else
    printf '%s\n' 'Battery: unavailable'
  fi
}

codex_cli_permission_bridge_path() {
  local candidate start_dir
  start_dir="$(session_start_dir 2>/dev/null || print -r -- "$SESSION_DIR")"
  for candidate in \
    "$start_dir/tools/macos_permission_bridge.sh" \
    "$PWD/tools/macos_permission_bridge.sh" \
    "$HOME/remote/app/tools/macos_permission_bridge.sh" \
    "$HOME/remote/app/sshcontroll-mobile/tools/macos_permission_bridge.sh" \
    "$HOME/remote/app/a-control-mobile/tools/macos_permission_bridge.sh"
  do
    candidate="${candidate/#\~/$HOME}"
    if [[ -x "$candidate" || -f "$candidate" ]]; then
      print -r -- "$candidate"
      return 0
    fi
  done
  return 1
}

