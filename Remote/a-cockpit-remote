#!/bin/zsh
set -euo pipefail

export PATH="$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
if [[ -z "${LANG:-}" || "${LANG:-}" == "C" || "${LANG:-}" == "POSIX" ]]; then
  export LANG="en_US.UTF-8"
fi
if [[ -z "${LC_CTYPE:-}" || "${LC_CTYPE:-}" == "C" || "${LC_CTYPE:-}" == "POSIX" ]]; then
  export LC_CTYPE="UTF-8"
fi

SCRIPT_PATH="${0:A}"
SHELL_SESSION="${A_COCKPIT_SHELL_SESSION:-shell-main}"
CODEX_SESSION="${A_COCKPIT_CODEX_SESSION:-codex-main}"
CODEX_HISTORY_ID="${A_COCKPIT_CODEX_HISTORY_ID:-}"
CLAUDE_SESSION="${A_COCKPIT_CLAUDE_SESSION:-claude-main}"
MONITOR_SESSION="${A_COCKPIT_MONITOR_SESSION:-monitor-main}"
SESSION_DIR="${A_COCKPIT_SESSION_DIR:-$HOME}"
HISTORY_LIMIT="${A_COCKPIT_HISTORY_LIMIT:-50000}"
HISTORY_CAPTURE_LINES="${A_COCKPIT_HISTORY_LINES:-14000}"
CODEX_BIN="${A_COCKPIT_CODEX_BIN:-}"
CLAUDE_BIN="${A_COCKPIT_CLAUDE_BIN:-}"
PERMISSION_HOST_APP="$HOME/Applications/A-Cockpit Permission Host.app"
CODEX_CLI_PERMISSION_HOST_APP="$HOME/Applications/Codex CLI Permission Host.app"
CODEX_CLI_PERMISSION_HOST_BUNDLE="local.codex.cli-permission-host"
TK_WRAPPER="$HOME/.local/bin/a-cockpit-tk-python"
CODEX_QUEUE_PLUGIN_MODE="${A_COCKPIT_CODEX_QUEUE_PLUGIN_MODE:-full}"
typeset -a CODEX_QUEUE_SAFE_RUNTIME_ARGS
CODEX_QUEUE_SAFE_RUNTIME_ARGS=(
  "-c" "features.apps=false"
  "-c" "features.plugins=false"
  "-c" "features.tool_search=false"
  "-c" "features.tool_suggest=false"
  "-c" "apps._default.enabled=false"
  "-c" "mcp_servers={}"
  "-c" "plugins={}"
)

choose_writable_dir() {
  local candidate
  for candidate in "$@"; do
    [[ -z "$candidate" ]] && continue
    candidate="${candidate/#\~/$HOME}"
    if mkdir -p "$candidate" 2>/dev/null && [[ -w "$candidate" ]]; then
      print -r -- "$candidate"
      return 0
    fi
  done
  candidate="/tmp/a-cockpit-${UID:-$(id -u)}"
  mkdir -p "$candidate" 2>/dev/null || true
  print -r -- "$candidate"
}

STATE_DIR="$(choose_writable_dir "${A_COCKPIT_STATE_DIR:-}" "$HOME/.cache/a-cockpit" "${TMPDIR:-/tmp}/a-cockpit-${UID:-$(id -u)}")"
CODEX_TOKEN_STATUS_SESSION="${A_COCKPIT_CODEX_TOKEN_SESSION:-a-control-token-status}"
CODEX_TOKEN_STATUS_CACHE="$STATE_DIR/codex-token-status.txt"
PERMISSION_DIR="$(choose_writable_dir "${A_COCKPIT_PERMISSION_DIR:-}" "$HOME/.a-cockpit-permission-test" "$STATE_DIR/permission-test")"
GUI_RUN_STATE="$STATE_DIR/gui-run-last.log"
FAN_RPM_CACHE="$STATE_DIR/fan-rpm-last.txt"
FAN_APPLY_RESULT="$PERMISSION_DIR/mfc-preset-result.txt"

mfc_app_path() {
  local candidate
  for candidate in "/Applications/Macs Fan Control.app" "$HOME/Applications/Macs Fan Control.app"; do
    if [[ -d "$candidate" ]]; then
      print -r -- "$candidate"
      return 0
    fi
  done
  return 1
}

mfc_is_installed() {
  mfc_app_path >/dev/null 2>&1
}

mfc_not_installed_message() {
  printf 'Macs Fan Control is not installed on A.\n'
}

resolve_configured_bin() {
  local candidate="$1"
  local expanded
  [[ -z "$candidate" ]] && return 1
  expanded="${candidate/#\~/$HOME}"
  if [[ "$expanded" == */* ]]; then
    [[ -x "$expanded" ]] && print -r -- "$expanded" && return 0
    return 1
  fi
  command -v "$expanded" 2>/dev/null
}

if [[ -n "$CODEX_BIN" ]]; then
  CODEX_BIN="$(resolve_configured_bin "$CODEX_BIN" 2>/dev/null || print -r -- "$CODEX_BIN")"
fi

if [[ -z "$CODEX_BIN" ]]; then
  if [[ -x "/Applications/Codex.app/Contents/Resources/codex" ]]; then
    CODEX_BIN="/Applications/Codex.app/Contents/Resources/codex"
  elif command -v codex >/dev/null 2>&1; then
    CODEX_BIN="$(command -v codex)"
  fi
fi

if [[ -n "$CLAUDE_BIN" ]]; then
  CLAUDE_BIN="$(resolve_configured_bin "$CLAUDE_BIN" 2>/dev/null || print -r -- "$CLAUDE_BIN")"
fi

if [[ -z "$CLAUDE_BIN" ]]; then
  if command -v claude >/dev/null 2>&1; then
    CLAUDE_BIN="$(command -v claude)"
  elif [[ -x "$HOME/.claude/local/claude" ]]; then
    CLAUDE_BIN="$HOME/.claude/local/claude"
  elif [[ -x "/opt/homebrew/bin/claude" ]]; then
    CLAUDE_BIN="/opt/homebrew/bin/claude"
  elif [[ -x "/usr/local/bin/claude" ]]; then
    CLAUDE_BIN="/usr/local/bin/claude"
  fi
fi

find_tk_python() {
  local candidates candidate
  candidates=(
    "${A_COCKPIT_TK_PYTHON:-}"
    "/usr/local/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/Current/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3"
    "/usr/bin/python3"
    "/opt/homebrew/bin/python3"
  )
  for candidate in $candidates; do
    if [[ -n "$candidate" && -x "$candidate" ]]; then
      if "$candidate" -c 'import tkinter' >/dev/null 2>&1; then
        print -r -- "$candidate"
        return 0
      fi
    fi
  done
  return 1
}

install_tk_wrapper() {
  local tk_python
  tk_python="$(find_tk_python 2>/dev/null || true)"
  if [[ -z "$tk_python" ]]; then
    return 1
  fi
  mkdir -p "${TK_WRAPPER:h}"
  cat > "$TK_WRAPPER" <<EOF
#!/bin/zsh
exec "$tk_python" "\$@"
EOF
  chmod 755 "$TK_WRAPPER"
  print -r -- "$tk_python"
}

install_permission_host_app() {
  local app_contents app_macos plist launcher runner launcher_source
  app_contents="$PERMISSION_HOST_APP/Contents"
  app_macos="$app_contents/MacOS"
  plist="$app_contents/Info.plist"
  launcher="$app_macos/a-cockpit-permission-host"
  runner="$app_macos/a-cockpit-permission-host-runner.zsh"
  launcher_source="$app_macos/a-cockpit-permission-host-launcher.c"

  if [[ "${A_COCKPIT_PERMISSION_HOST_FORCE_INSTALL:-0}" != "1" && -x "$launcher" && -x "$runner" && -f "$plist" ]]; then
    if grep -q 'A_COCKPIT_PERMISSION_HOST_RUNNER=3' "$runner" 2>/dev/null &&
      file "$launcher" 2>/dev/null | grep -q 'Mach-O'; then
      mkdir -p "$PERMISSION_DIR"
      return 0
    fi
  fi

  mkdir -p "$app_macos" "$PERMISSION_DIR"

  cat > "$plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>a-cockpit-permission-host</string>
  <key>CFBundleIdentifier</key>
  <string>local.a-cockpit.permission-host</string>
  <key>CFBundleName</key>
  <string>A-Cockpit Permission Host</string>
  <key>CFBundleDisplayName</key>
  <string>A-Cockpit Permission Host</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleVersion</key>
  <string>1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
PLIST

  cat > "$runner" <<'RUNNER'
#!/bin/zsh
set -u
# A_COCKPIT_PERMISSION_HOST_RUNNER=3
export PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
PERMISSION_DIR="$HOME/.a-cockpit-permission-test"
LOG="$PERMISSION_DIR/permission-host.log"
RESULT="$PERMISSION_DIR/mfc-preset-result.txt"
mkdir -p "$PERMISSION_DIR"

find_tk_python() {
  local candidates candidate
  candidates=(
    "${A_COCKPIT_TK_PYTHON:-}"
    "$HOME/.local/bin/a-cockpit-tk-python"
    "/usr/local/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/Current/bin/python3"
    "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3"
    "/usr/bin/python3"
  )
  for candidate in $candidates; do
    if [[ -n "$candidate" && -x "$candidate" ]] && "$candidate" -c 'import tkinter' >/dev/null 2>&1; then
      print -r -- "$candidate"
      return 0
    fi
  done
  return 1
}

log_run() {
  {
    printf '\n=== %s  %s ===\n' "$1" "$(date '+%Y-%m-%d %H:%M:%S')"
    shift
    "$@"
    printf 'exit=%s\n' "$?"
  } >> "$LOG" 2>&1
}

run_screenshot() {
  log_run screencapture /usr/sbin/screencapture -x "$PERMISSION_DIR/screenshot-test.png"
}

run_automation() {
  log_run system-events osascript -e 'tell application "System Events" to get name of first process'
  log_run finder-automation osascript -e 'tell application "Finder" to get name of startup disk'
}

run_mfc_dump() {
  {
    printf '\n=== mfc-dump  %s ===\n' "$(date '+%Y-%m-%d %H:%M:%S')"
    osascript <<'APPLESCRIPT'
on describeElement(theElement, depth)
  set prefix to ""
  repeat with i from 1 to depth
    set prefix to prefix & "  "
  end repeat

  set roleText to ""
  set nameText to ""
  set descriptionText to ""
  set valueText to ""
  set positionText to ""
  set sizeText to ""
  try
    set roleText to role of theElement as text
  end try
  try
    set nameText to name of theElement as text
  end try
  try
    set descriptionText to description of theElement as text
  end try
  try
    set valueText to value of theElement as text
  end try
  try
    set p to position of theElement
    set positionText to (item 1 of p as text) & "," & (item 2 of p as text)
  end try
  try
    set s to size of theElement
    set sizeText to (item 1 of s as text) & "x" & (item 2 of s as text)
  end try

  return prefix & roleText & " name=[" & nameText & "] desc=[" & descriptionText & "] value=[" & valueText & "] pos=[" & positionText & "] size=[" & sizeText & "]"
end describeElement

on appendChildren(theElement, depth, outputLines)
  try
    tell application "System Events" to set childElements to UI elements of theElement
    repeat with childElement in childElements
      set end of outputLines to my describeElement(childElement, depth)
      if depth < 5 then set outputLines to my appendChildren(childElement, depth + 1, outputLines)
    end repeat
  end try
  return outputLines
end appendChildren

tell application "Macs Fan Control" to activate
delay 1
set outputLines to {}
tell application "System Events"
  tell process "Macs Fan Control"
    set frontmost to true
    delay 1
    set w to window 1
    set end of outputLines to my describeElement(w, 0)
    set outputLines to my appendChildren(w, 1, outputLines)
  end tell
end tell
set oldDelims to AppleScript's text item delimiters
set AppleScript's text item delimiters to linefeed
set joined to outputLines as text
set AppleScript's text item delimiters to oldDelims
return joined
APPLESCRIPT
    printf 'exit=%s\n' "$?"
  } >> "$LOG" 2>&1
}

run_mfc_preset() {
  local requested="${1:-}"
  local target=""
  local osarc=0
  case "$requested" in
    auto|automatic)
      requested="auto"
      target="Automatic"
      ;;
    full|fullblast|full-blast)
      requested="fullblast"
      target="Full blast"
      ;;
    3000|4000|5000)
      target="$requested"
      ;;
    *)
      {
        printf 'ok=0\n'
        printf 'mode=%s\n' "$requested"
        printf 'error=usage: mfc-preset {auto|fullblast|3000|4000|5000}\n'
      } > "$RESULT"
      return 64
      ;;
  esac

  {
    printf '\n=== mfc-preset %s  %s ===\n' "$requested" "$(date '+%Y-%m-%d %H:%M:%S')"
    osascript - "$target" <<'APPLESCRIPT' || osarc=$?
on normalizeText(theText)
  set valueText to theText as text
  set valueText to do shell script "/bin/echo " & quoted form of valueText & " | /usr/bin/tr '[:upper:]' '[:lower:]'"
  return valueText
end normalizeText

on namesMatch(candidateName, targetName)
  set c to my normalizeText(candidateName)
  set t to my normalizeText(targetName)
  if c is t then return true
  if t is "full blast" and c contains "full" and c contains "blast" then return true
  if t is "automatic" and c contains "automatic" then return true
  if t is "automatic" and c is "auto" then return true
  if t is "3000" and c contains "3000" then return true
  if t is "4000" and c contains "4000" then return true
  if t is "5000" and c contains "5000" then return true
  return false
end namesMatch

on clickNamedMenuItem(targetName, menuElement)
  tell application "System Events"
    repeat with itemElement in menu items of menuElement
      set itemName to ""
      try
        set itemName to name of itemElement as text
      end try
      if itemName is not "" and my namesMatch(itemName, targetName) then
        click itemElement
        return true
      end if
      try
        perform action "AXShowMenu" of itemElement
        delay 0.15
      end try
      try
        if exists menu 1 of itemElement then
          if my clickNamedMenuItem(targetName, menu 1 of itemElement) then return true
        end if
      end try
    end repeat
  end tell
  return false
end clickNamedMenuItem

on clickPresetFromMenuBar(targetName)
  tell application "System Events"
    if not (exists process "Macs Fan Control") then error "Macs Fan Control process is not running"
    tell process "Macs Fan Control"
      set foundMenuBarItem to false
      repeat with barNumber from 2 to 1 by -1
        try
          set barItems to menu bar items of menu bar barNumber
          repeat with barItem in barItems
            set foundMenuBarItem to true
            click barItem
            delay 0.25
            try
              if exists menu 1 of barItem then
                if my clickNamedMenuItem(targetName, menu 1 of barItem) then return true
              end if
            end try
            key code 53
            delay 0.1
          end repeat
        end try
      end repeat
      if not foundMenuBarItem then error "Macs Fan Control menu-bar item was not accessible"
    end tell
  end tell
  return false
end clickPresetFromMenuBar

on run argv
  set targetName to item 1 of argv
  tell application "Macs Fan Control" to launch
  delay 0.5
  if my clickPresetFromMenuBar(targetName) then
    return "clicked " & targetName
  else
    error "preset not found: " & targetName
  end if
end run
APPLESCRIPT
    printf 'exit=%s\n' "$osarc"
  } >> "$LOG" 2>&1

  if [[ "$osarc" == 0 ]]; then
    {
      printf 'ok=1\n'
      printf 'mode=%s\n' "$requested"
      printf 'target=%s\n' "$target"
    } > "$RESULT"
  else
    {
      printf 'ok=0\n'
      printf 'mode=%s\n' "$requested"
      printf 'target=%s\n' "$target"
      printf 'error=Macs Fan Control menu-bar preset click failed. Grant Accessibility to A-Cockpit Permission Host on A.\n'
    } > "$RESULT"
  fi
  return "$osarc"
}

run_tk() {
  local tk_python
  tk_python="$(find_tk_python 2>/dev/null || true)"
  if [[ -z "$tk_python" ]]; then
    print -r -- "No Tk-capable Python found." >> "$LOG"
    return 1
  fi
  "$tk_python" <<'PY' >> "$LOG" 2>&1
import tkinter as tk
root = tk.Tk()
root.title("A-Cockpit Tk permission test")
label = tk.Label(root, text="Tk is running on computer A via A-Cockpit Permission Host")
label.pack(padx=40, pady=30)
root.after(4000, root.destroy)
root.mainloop()
PY
}

run_file() {
  local script_path="${1:-}"
  local log_path="${2:-}"
  local cwd="${3:-$HOME}"
  local rc=0
  if [[ -z "$script_path" ]]; then
    printf 'run-file requires a script path\n' >> "$LOG"
    return 64
  fi
  [[ -z "$log_path" ]] && log_path="$PERMISSION_DIR/gui-run-$(date '+%Y%m%d-%H%M%S').log"
  mkdir -p "${log_path:h}" "$PERMISSION_DIR"
  {
    printf '\n=== gui-run-file  %s ===\n' "$(date '+%Y-%m-%d %H:%M:%S')"
    printf 'script=%s\n' "$script_path"
    printf 'cwd=%s\n' "$cwd"
    printf 'user=[local-user]\n'
    printf 'console_user=[local-console-user]\n'
    printf 'path=%s\n' "$PATH"
    if [[ ! -f "$script_path" ]]; then
      printf 'error=script not found\n'
      printf 'exit=66\n'
      exit 66
    fi
    chmod 755 "$script_path" 2>/dev/null || true
    cd "$cwd" 2>/dev/null || cd "$HOME"
    "$script_path"
    rc=$?
    printf '\nexit=%s\n' "$rc"
    exit "$rc"
  } >> "$log_path" 2>&1
}

open_folder_after=1
case "${1:-prep}" in
  screenshot)
    run_screenshot
    ;;
  automation)
    run_automation
    ;;
  mfc-dump)
    open_folder_after=0
    run_mfc_dump
    ;;
  mfc-preset)
    open_folder_after=0
    run_mfc_preset "${2:-}"
    ;;
  tk)
    run_tk
    ;;
  run-file)
    open_folder_after=0
    run_file "${2:-}" "${3:-}" "${4:-$HOME}"
    ;;
  prep|all)
    run_screenshot
    run_automation
    run_tk
    ;;
esac
if [[ "$open_folder_after" == "1" ]]; then
  open "$PERMISSION_DIR" >/dev/null 2>&1 || true
fi
RUNNER
  chmod 755 "$runner"

  cat > "$launcher_source" <<'C'
#include <libgen.h>
#include <limits.h>
#include <mach-o/dyld.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

int main(int argc, char *argv[]) {
  char executable[PATH_MAX];
  uint32_t size = sizeof(executable);
  if (_NSGetExecutablePath(executable, &size) != 0) {
    fprintf(stderr, "A-Cockpit Permission Host launcher path is too long.\\n");
    return 127;
  }

  char dirbuf[PATH_MAX];
  strncpy(dirbuf, executable, sizeof(dirbuf));
  dirbuf[sizeof(dirbuf) - 1] = '\\0';
  char *dir = dirname(dirbuf);

  char runner[PATH_MAX];
  snprintf(runner, sizeof(runner), "%s/a-cockpit-permission-host-runner.zsh", dir);

  char **child_argv = calloc((size_t)argc + 2, sizeof(char *));
  if (child_argv == NULL) {
    perror("calloc");
    return 127;
  }
  child_argv[0] = "/bin/zsh";
  child_argv[1] = runner;
  for (int i = 1; i < argc; i++) {
    child_argv[i + 1] = argv[i];
  }
  child_argv[argc + 1] = NULL;

  execv("/bin/zsh", child_argv);
  perror("execv");
  return 127;
}
C

  if command -v clang >/dev/null 2>&1; then
    clang -Os -o "$launcher" "$launcher_source" >/dev/null 2>&1 || cp "$runner" "$launcher"
  else
    cp "$runner" "$launcher"
  fi
  chmod 755 "$launcher"
  codesign --force --sign - "$launcher" >/dev/null 2>&1 || true
  codesign --force --deep --sign - "$PERMISSION_HOST_APP" >/dev/null 2>&1 || true
}

need_tmux() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux is not installed or not on PATH." >&2
    exit 127
  fi
  tmux set-option -g history-limit "$HISTORY_LIMIT" 2>/dev/null || true
  tmux set-environment -g LANG "$LANG" 2>/dev/null || true
  tmux set-environment -g LC_CTYPE "$LC_CTYPE" 2>/dev/null || true
}

session_start_dir() {
  local dir
  dir="${SESSION_DIR/#\~/$HOME}"
  if [[ -d "$dir" ]]; then
    print -r -- "$dir"
  else
    print -r -- "$HOME"
  fi
}

ensure_shell() {
  need_tmux
  if ! tmux has-session -t "$SHELL_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SHELL_SESSION" -c "$(session_start_dir)" "${SHELL:-/bin/zsh}" -il
  fi
}

ensure_codex() {
  need_tmux
  if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
    echo "Codex CLI was not found. Expected codex on PATH, Codex.app, or a valid SSHcontroll Codex Path override." >&2
    exit 127
  fi
  if ! tmux has-session -t "$CODEX_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$CODEX_SESSION" -c "$(session_start_dir)" "$CODEX_BIN"
    codex_mark_history ""
    codex_mark_runtime "interactive-full"
  fi
}

ensure_claude() {
  need_tmux
  if [[ -z "$CLAUDE_BIN" || ! -x "$CLAUDE_BIN" ]]; then
    echo "Claude Code CLI was not found. Expected claude on PATH or a valid A_COCKPIT_CLAUDE_BIN path." >&2
    exit 127
  fi
  if ! tmux has-session -t "$CLAUDE_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$CLAUDE_SESSION" -c "$(session_start_dir)" "$CLAUDE_BIN"
  fi
}

codex_app_path() {
  if [[ -d "/Applications/Codex.app" ]]; then
    print -r -- "/Applications/Codex.app"
    return 0
  fi
  return 1
}

codex_app_bin() {
  if [[ -x "/Applications/Codex.app/Contents/Resources/codex" ]]; then
    print -r -- "/Applications/Codex.app/Contents/Resources/codex"
    return 0
  fi
  return 1
}

codex_app_identity_report() {
  local app bin bundle_id
  app="$(codex_app_path 2>/dev/null || true)"
  bin="$(codex_app_bin 2>/dev/null || true)"
  printf '%s\n' 'Codex app permission identity'
  if [[ -n "$app" ]]; then
    printf 'Codex.app: installed\n'
    printf 'App path: %s\n' "$app"
    bundle_id="$(mdls -name kMDItemCFBundleIdentifier -raw "$app" 2>/dev/null || true)"
    [[ -n "$bundle_id" && "$bundle_id" != "(null)" ]] && printf 'Bundle id: %s\n' "$bundle_id"
  else
    printf 'Codex.app: not found in /Applications\n'
  fi
  if [[ -n "$bin" ]]; then
    printf 'codex_bin: %s\n' "$bin"
    if [[ "$CODEX_BIN" == "$bin" ]]; then
      printf 'SSHcontroll Codex launch: stable Codex.app binary\n'
    else
      printf 'SSHcontroll Codex launch: %s\n' "${CODEX_BIN:-missing}"
    fi
  else
    printf 'codex_bin: missing\n'
  fi
  printf 'Persistence note: macOS keeps privacy grants only for the same app identity/path. Keep Codex.app in /Applications; leave SSHcontroll Codex Path blank unless you intentionally need a custom binary.\n'
}

macs_fan_control_snapshot() {
  local active_preset label
  if ! mfc_is_installed; then
    mfc_not_installed_message
    return 0
  fi
  active_preset="$(defaults read com.crystalidea.macsfancontrol ActivePreset 2>/dev/null || true)"
  if [[ -n "$active_preset" ]]; then
    label="$(mfc_preset_label "$active_preset")"
    printf 'Macs Fan Control preset: %s (%s)\n' "${label:-unknown}" "$active_preset"
  fi
  mfc_custom_presets_report
}

mfc_custom_presets_report() {
  /usr/bin/python3 <<'PY' 2>/dev/null || true
import base64
import re
import subprocess

proc = subprocess.run(
    ["/usr/bin/defaults", "read", "com.crystalidea.macsfancontrol", "CustomPresets"],
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
)
if proc.returncode != 0:
    raise SystemExit(0)
values = []
for quoted, bare in re.findall(r'"([^"]+)"|([A-Za-z0-9+/=]{8,})', proc.stdout):
    value = quoted or bare
    if value and value not in values:
        values.append(value)
for index, value in enumerate(values):
    try:
        decoded = base64.b64decode(value).decode("utf-8", "replace")
    except Exception:
        continue
    parts = decoded.split("|")
    if not parts:
        continue
    name = parts[0]
    if name.isdigit() or name.startswith("macctl-"):
        shown = name.replace("macctl-", "")
        print(f"Macs Fan Control custom preset {index}: {shown} rpm")
PY
}

mfc_preset_label() {
  local active="${1:-}"
  /usr/bin/python3 - "$active" <<'PY' 2>/dev/null || true
import base64
import re
import subprocess
import sys

active = sys.argv[1]
if active == "Predefined:0":
    print("Automatic")
    raise SystemExit
if active == "Predefined:1":
    print("Full Blast")
    raise SystemExit
if not active.startswith("Custom:"):
    print(active or "unknown")
    raise SystemExit
try:
    wanted_index = int(active.split(":", 1)[1])
except Exception:
    print(active)
    raise SystemExit
proc = subprocess.run(
    ["/usr/bin/defaults", "read", "com.crystalidea.macsfancontrol", "CustomPresets"],
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
)
values = []
if proc.returncode == 0:
    for quoted, bare in re.findall(r'"([^"]+)"|([A-Za-z0-9+/=]{8,})', proc.stdout):
        value = quoted or bare
        if value and value not in values:
            values.append(value)
if 0 <= wanted_index < len(values):
    try:
        decoded = base64.b64decode(values[wanted_index]).decode("utf-8", "replace")
        name = decoded.split("|", 1)[0].replace("macctl-", "")
        print(f"{name} RPM" if name.isdigit() else name)
    except Exception:
        print(active)
else:
    print(active)
PY
}

fan_mode() {
  local active label
  if ! mfc_is_installed; then
    printf 'not installed\n'
    return 0
  fi
  active="$(defaults read com.crystalidea.macsfancontrol ActivePreset 2>/dev/null || true)"
  case "$active" in
    Predefined:0)
      printf 'auto\n'
      ;;
    Predefined:1)
      printf 'fullblast\n'
      ;;
    Custom:*)
      label="$(mfc_preset_label "$active" | tr '[:upper:]' '[:lower:]')"
      case "$label" in
        *3000*) printf '3000\n' ;;
        *4000*) printf '4000\n' ;;
        *5000*) printf '5000\n' ;;
        *) printf '%s\n' "$active" ;;
      esac
      ;;
    *)
      printf '%s\n' "${active:-unknown}"
      ;;
  esac
}

