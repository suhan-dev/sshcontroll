        with latest_gpu as (
          select max(time) as t from gpu where interval = 5
        )
        select 'GPU: processor ' || printf('%.1f', processor) ||
               '%, memory ' || printf('%.1f', memory) || '%'
        from gpu, latest_gpu
        where gpu.time = latest_gpu.t and gpu.interval = 5
        order by key
        limit 4;
      " 2>/dev/null || true
      ;;
    memory)
      sqlite3 "$db" "
        with latest_memory as (
