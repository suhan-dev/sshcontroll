fan_rpm_snapshot_once() {
  local direct
  if command -v a-cockpit-smc-rpm >/dev/null 2>&1; then
    direct="$(a-cockpit-smc-rpm 2>/dev/null || true)"
  else
    direct=""
  fi

  if [[ -n "$direct" ]]; then
    printf '%s\n' "$direct" | awk '
      match($0, /Fan [0-9]+ (actual|direct): [0-9.]+ rpm/) {
        gsub(/ (actual|direct): /, " RPM: ")
        print
      }
    '
