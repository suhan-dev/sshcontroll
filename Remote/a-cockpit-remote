computer_snapshot() {
  local shot tree script
  install_permission_host_app
  mkdir -p "$PERMISSION_DIR"
  shot="$PERMISSION_DIR/computer-screen.png"
  tree="$PERMISSION_DIR/computer-tree.txt"
  script="$PERMISSION_DIR/computer-snapshot.zsh"
  cat > "$script" <<EOF
#!/bin/zsh
set +e
/usr/sbin/screencapture -x "$shot"
/usr/bin/osascript > "$tree" <<'APPLESCRIPT'
on cleanText(theValue)
  try
    set textValue to theValue as text
    set textValue to do shell script "/bin/echo " & quoted form of textValue & " | /usr/bin/tr '\\r' '\\n' | /usr/bin/head -c 220"
    return textValue
  on error
    return ""
  end try
end cleanText

on describeElement(theElement, depth, maxDepth)
  if depth > maxDepth then return ""
  set prefix to ""
  repeat with i from 1 to depth
    set prefix to prefix & "  "
  end repeat
  set roleText to ""
  set nameText to ""
  set valueText to ""
  try
    set roleText to role of theElement as text
  end try
  try
    set nameText to my cleanText(name of theElement)
  end try
  try
    set valueText to my cleanText(value of theElement)
  end try
  set lineText to prefix & roleText
  if nameText is not "" then set lineText to lineText & " name=" & quoted form of nameText
  if valueText is not "" then set lineText to lineText & " value=" & quoted form of valueText
  set outputText to lineText & linefeed
  try
    tell application "System Events" to set childElements to UI elements of theElement
    set childCount to count childElements
    set limitCount to childCount
    if limitCount > 30 then set limitCount to 30
    repeat with childIndex from 1 to limitCount
      set outputText to outputText & my describeElement(item childIndex of childElements, depth + 1, maxDepth)
    end repeat
    if childCount > limitCount then set outputText to outputText & prefix & "  ... " & ((childCount - limitCount) as text) & " more" & linefeed
  end try
  return outputText
end describeElement

tell application "System Events"
  set frontApps to application processes whose frontmost is true
  if (count frontApps) is 0 then
    return "frontmost=unknown"
  end if
  set frontApp to item 1 of frontApps
  set appName to name of frontApp as text
  set outputText to "frontmost=" & appName & linefeed
  try
    set outputText to outputText & "windows=" & ((count windows of frontApp) as text) & linefeed
    if (count windows of frontApp) > 0 then
      set outputText to outputText & my describeElement(window 1 of frontApp, 0, 3)
    end if
  end try
  return outputText
end tell
APPLESCRIPT
echo "screenshot=$shot"
echo "tree=$tree"
if [[ -s "$tree" ]]; then
  echo "----------------------------------------"
  /usr/bin/head -120 "$tree"
fi
EOF
  chmod 755 "$script"
  computer_use_run_host_script "$script" "$HOME"
}

