codex_queue_pane_is_interactive() {
  local pane_text="$1"
  [[ "$pane_text" == *"Approaching rate limits"* \
    || "$pane_text" == *"Press enter to confirm or esc to go back"* \
    || "$pane_text" == *"Switch to gpt-"* ]]
}

codex_queue_pane_is_busy() {
  local pane_text="$1"
  local lower
  lower="$(print -r -- "$pane_text" | tr '[:upper:]' '[:lower:]')"
  [[ "$lower" == *"working"* \
    || "$lower" == *"thinking"* \
    || "$lower" == *"esc to interrupt"* \
    || "$lower" == *"tab to queue message"* ]]
}

codex_queue_wait_for_send_ack() {
  local target="$1"
  local waited=0
  local pane_text
  while (( waited < 48 )); do
    pane_text="$(codex_queue_pane_text "$target")"
    if codex_queue_pane_is_busy "$pane_text"; then
      return 0
    fi
    if codex_queue_pane_is_interactive "$pane_text"; then
      return 0
    fi
    sleep 0.25
    waited=$((waited + 1))
  done
  return 1
}

codex_queue_read_file() {
  local file_path="$1"
  [[ -f "$file_path" ]] && cat "$file_path" || true
}

codex_queue_sorted_jobs() {
  local root="$1"
  local job order
  local -a jobs
  jobs=("$root"/queued/*(N))
  for job in "${jobs[@]}"; do
    order="$(codex_queue_read_file "$job/order")"
    [[ -n "$order" ]] || order="${job:t}"
    printf '%s\t%s\n' "$order" "$job"
  done | LC_ALL=C sort -s -k1,1 -k2,2 | cut -f2-
}

codex_queue_worker_jobs() {
  local root="$1"
  local job
  local -a jobs steer_jobs send_jobs
  jobs=("${(@f)$(codex_queue_sorted_jobs "$root")}")
  for job in "${jobs[@]}"; do
    [[ -n "$job" ]] || continue
    if [[ -f "$job/is-steer" ]]; then
      steer_jobs+=("$job")
    else
      send_jobs+=("$job")
    fi
  done
  for job in "${steer_jobs[@]}" "${send_jobs[@]}"; do
    [[ -n "$job" ]] && print -r -- "$job"
  done
}

codex_queue_worker_heartbeat_file() {
