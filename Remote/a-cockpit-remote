codex_dev_setup() {
  python3 <<'PY'
from pathlib import Path
import re
import time

config = Path.home() / ".codex" / "config.toml"
config.parent.mkdir(parents=True, exist_ok=True)
text = config.read_text() if config.exists() else ""
if config.exists():
    backup = config.with_name(f"config.toml.sshcontroll-backup-{time.strftime('%Y%m%d-%H%M%S')}")
    backup.write_text(text)

def set_top_level(src, key, value):
    pattern = re.compile(rf"(?m)^{re.escape(key)}\s*=\s*.*$")
    line = f"{key} = {value}"
    if pattern.search(src):
        return pattern.sub(line, src, count=1)
    first_section = re.search(r"(?m)^\[", src)
    if first_section:
        return src[:first_section.start()].rstrip() + "\n" + line + "\n\n" + src[first_section.start():].lstrip()
    return src.rstrip() + "\n" + line + "\n"

for key, value in [
    ("model", '"gpt-5.5"'),
    ("model_reasoning_effort", '"xhigh"'),
    ("approval_policy", '"never"'),
    ("sandbox_mode", '"danger-full-access"'),
    ("suppress_unstable_features_warning", "true"),
]:
    text = set_top_level(text, key, value)

plugins = [
    "documents@openai-primary-runtime",
    "spreadsheets@openai-primary-runtime",
    "presentations@openai-primary-runtime",
    "computer-use@openai-bundled",
    "browser@openai-bundled",
    "chrome@openai-bundled",
    "github@openai-curated",
    "linear@openai-curated",
    "zotero@openai-curated",
    "life-science-research@openai-curated",
    "scite@openai-curated",
    "figma@openai-curated",
    "canva@openai-curated",
    "notion@openai-curated",
    "vercel@openai-curated",
]

def ensure_plugin(src, plugin):
    header = f'[plugins."{plugin}"]'
    escaped_header = re.escape(header)
    section = re.search(rf"(?ms)^{escaped_header}\s*$.*?(?=^\[|\Z)", src)
    if not section:
        return src.rstrip() + f"\n\n{header}\nenabled = true\n"
    block = section.group(0)
    if re.search(r"(?m)^enabled\s*=", block):
        new_block = re.sub(r"(?m)^enabled\s*=\s*.*$", "enabled = true", block, count=1)
    else:
        new_block = block.rstrip() + "\nenabled = true\n"
    return src[:section.start()] + new_block + src[section.end():]

for plugin in plugins:
    text = ensure_plugin(text, plugin)

config.write_text(text.rstrip() + "\n")
print("Codex developer config ready.")
print("model=gpt-5.5")
print("model_reasoning_effort=xhigh")
print("approval_policy=never")
print("sandbox_mode=danger-full-access")
print("plugins=" + ", ".join(plugins))
PY
}

