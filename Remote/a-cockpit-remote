state_db = pathlib.Path.home() / ".codex" / "state_5.sqlite"
if state_db.exists():
    try:
        with sqlite3.connect(str(state_db)) as conn:
            for session_id, cwd, title, rollout_path, source, thread_source in conn.execute(
                "select id, cwd, title, rollout_path, source, coalesce(thread_source,'') from threads"
            ):
                if not session_id:
                    continue
                if str(thread_source or "").lower() == "subagent" or "subagent" in str(source or "").lower():
                    continue
                title_text = " ".join(str(title or "").split()).lower()
                if title_text.startswith("/status") or title_text == "status":
                    continue
                try:
                    cwd_path = pathlib.Path(cwd or "").expanduser().resolve()
                except Exception:
                    cwd_path = pathlib.Path(cwd or "").expanduser()
                if str(cwd_path) != str(target):
                    continue
                mtime = int(state_db.stat().st_mtime)
                if rollout_path:
                    try:
                        mtime = int(pathlib.Path(rollout_path).expanduser().stat().st_mtime)
                    except Exception:
                        pass
                if min_mtime and mtime < min_mtime:
                    continue
                matches.append((mtime, str(session_id)))
    except Exception:
        pass

for path in base.glob("**/*.jsonl"):
    try:
        stat = path.stat()
    except OSError:
        continue
    meta = {}
    first_user = ""
    try:
        with path.open(errors="replace") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if obj.get("type") == "session_meta":
                    meta = obj.get("payload") or {}
                    source = meta.get("source")
                    source_text = source if isinstance(source, str) else json.dumps(source or "", ensure_ascii=False)
                    if str(meta.get("thread_source") or "").lower() == "subagent" or "subagent" in source_text.lower():
                        meta = {"_skip": True}
                        break
                    continue
                if obj.get("type") == "response_item":
                    payload = obj.get("payload") or {}
                    item = payload.get("item")
                    source = item if isinstance(item, dict) else payload
                    role = str(source.get("role") or payload.get("role") or "").lower()
                    kind = str(source.get("type") or payload.get("type") or "").lower()
                    if role == "user" or kind in {"user_message", "input_text"}:
                        first_user = json.dumps(source, ensure_ascii=False).lower()
                        break
    except Exception:
        continue
    if meta.get("_skip"):
        continue
    if first_user.lstrip().startswith('"/status') or "/status" in first_user[:200]:
        continue
    cwd = meta.get("cwd") or ""
    if not cwd:
        continue
    try:
        cwd_path = pathlib.Path(cwd).expanduser().resolve()
    except Exception:
        cwd_path = pathlib.Path(cwd).expanduser()
    if str(cwd_path) != str(target):
        continue
    if min_mtime and stat.st_mtime < min_mtime:
        continue
    session_id = meta.get("id") or path.stem.split("-")[-1]
    matches.append((stat.st_mtime, session_id))

if matches:
    seen = set()
    for _, session_id in sorted(matches, reverse=True):
        if session_id in seen:
            continue
        print(session_id)
        break
PY
}

codex_sync_history_record() {
  local session_id="${1:-}"
  local dir="${2:-}"
  local model="${3:-}"
  local effort="${4:-}"
  local title_hint="${5:-}"
  [[ -n "$session_id" ]] || return 1
  [[ -n "$dir" ]] || dir="$(session_start_dir)"
  python3 - "$session_id" "$dir" "$model" "$effort" "$title_hint" <<'PY'
import json
import datetime
import pathlib
import re
import sqlite3
import sys
import time

session_id, directory, model, effort, title_hint = sys.argv[1:6]
home = pathlib.Path.home()
base = home / ".codex" / "sessions"
state_db = home / ".codex" / "state_5.sqlite"
if not state_db.exists():
    raise SystemExit(0)

def good_title(value):
    clean = " ".join(str(value or "").split())
    if not clean:
        return ""
    lower = clean.lower()
    blocked = (
        "<sshcontroll_attachments", "<environment_context", "{", "}",
        "subagent_notification", "process running with session id", "a_queue_",
        "codex_history_id:", "unable to locate image at",
        "steer the current codex work with this instruction",
        "basename:", "first line:", "smoke-test marker", "[@computer]",
    )
    if any(fragment in lower for fragment in blocked):
        return ""
    if re.match(r"^(cd(?:\s|$)|pwd(?:\s|$)|ls(?:\s|$)|clear$|/(status|model|permissions)\b)", clean, re.I):
        return ""
    if re.match(r"^Stage\s+\d+\b.*\brole:", clean, re.I):
        return ""
    code_tokens = (
        "def ", "class ", "struct ", "enum ", "func ", "return ", "self.",
        " = ", " -> ", "import ", "from ", "@override", "private ", "public ",
    )
    if any(token in lower for token in code_tokens):
        return ""
    if len(clean) > 96:
        clean = clean[:93].rstrip() + "..."
    return clean

def content_text(value):
    pieces = []
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        for item in value:
            text = content_text(item)
            if text:
                pieces.append(text)
    elif isinstance(value, dict):
        for key in ("text", "input_text", "output_text", "content", "message"):
            if key in value:
                text = content_text(value.get(key))
                if text:
                    pieces.append(text)
                    break
    return "\n".join(pieces).strip()

rollout_path = ""
cwd = directory
directory_title = pathlib.Path(directory).expanduser().name or "Codex session"
title = good_title(title_hint) or f"SSHcontroll: {directory_title}"
created = int(time.time())
updated = created
first_user = ""

if base.exists():
    for path in base.glob("**/*.jsonl"):
        meta = {}
        first_candidate = ""
        try:
            with path.open(errors="replace") as handle:
                for line in handle:
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    payload = obj.get("payload") or {}
                    if obj.get("type") == "session_meta":
                        meta = payload
                        continue
                    if not first_candidate and obj.get("type") == "response_item":
                        item = payload.get("item")
                        source = item if isinstance(item, dict) else payload
                        role = str(source.get("role") or payload.get("role") or "").lower()
                        kind = str(source.get("type") or payload.get("type") or "").lower()
                        if role == "user" or kind in {"user_message", "input_text"}:
                            first_candidate = content_text(source) or content_text(payload)
        except Exception:
            continue
        found_id = str(meta.get("id") or path.stem.split("-")[-1])
        if found_id != session_id:
            continue
        rollout_path = str(path)
        cwd = str(meta.get("cwd") or directory)
        try:
            stat = path.stat()
            created = int(stat.st_ctime)
            updated = int(stat.st_mtime)
        except Exception:
            pass
        first_user = first_candidate.strip()
        title = good_title(first_candidate) or title
        break

if not rollout_path:
    raise SystemExit(0)

preview = good_title(first_user) or title
now_ms = updated * 1000
created_ms = created * 1000
existing_title = ""

defaults = {
    "id": session_id,
    "rollout_path": rollout_path,
    "created_at": created,
    "updated_at": updated,
    "source": "vscode",
    "model_provider": "openai",
    "cwd": cwd,
    "title": title,
    "sandbox_policy": '{"type":"danger-full-access"}',
    "approval_mode": "never",
    "tokens_used": 0,
    "has_user_event": 1,
    "archived": 0,
    "archived_at": None,
    "git_sha": None,
    "git_branch": None,
    "git_origin_url": None,
    "cli_version": "codex-cli",
    "first_user_message": first_user,
    "agent_nickname": None,
    "agent_role": None,
    "memory_mode": "enabled",
    "model": model or None,
    "reasoning_effort": effort or None,
    "agent_path": None,
    "created_at_ms": created_ms,
    "updated_at_ms": now_ms,
    "thread_source": "user",
    "preview": preview,
}

try:
    with sqlite3.connect(str(state_db), timeout=3) as conn:
        columns = [row[1] for row in conn.execute("pragma table_info(threads)")]
        existing = conn.execute("select id, title from threads where id=?", (session_id,)).fetchone()
        if existing is not None:
            existing_title = str(existing[1] or "")
        if existing is None:
            insert_cols = [column for column in columns if column in defaults]
            values = [defaults[column] for column in insert_cols]
            placeholders = ",".join("?" for _ in insert_cols)
            conn.execute(
                f"insert or ignore into threads ({','.join(insert_cols)}) values ({placeholders})",
                values,
            )
        else:
            updates = {
                "rollout_path": rollout_path,
                "cwd": cwd,
                "updated_at": updated,
                "updated_at_ms": now_ms,
                "source": "vscode",
                "model_provider": "openai",
                "cli_version": "codex-cli",
                "has_user_event": 1,
                "model": model or None,
                "reasoning_effort": effort or None,
                "thread_source": "user",
                "preview": preview,
            }
            current_title = str(existing[1] or "")
            current_title_flat = " ".join(current_title.split())
            if (
                not current_title_flat
                or current_title_flat == "Codex session"
                or len(current_title_flat) > 140
                or "<sshcontroll_attachments" in current_title_flat.lower()
                or "<environment_context" in current_title_flat.lower()
                or "subagent_notification" in current_title_flat.lower()
                or "a_queue_" in current_title_flat.lower()
                or re.match(r"^(cd(?:\s|$)|pwd(?:\s|$)|ls(?:\s|$)|clear$|/(status|model|permissions)\b)", current_title_flat, re.I)
                or re.match(r"^Stage\s+\d+\b.*\brole:", current_title_flat, re.I)
                or current_title_flat.lower().startswith("this is the clean ")
            ):
                updates["title"] = title
            usable = {key: value for key, value in updates.items() if key in columns}
            if usable:
                assignments = ",".join(f"{key}=?" for key in usable)
                conn.execute(
                    f"update threads set {assignments} where id=?",
                    list(usable.values()) + [session_id],
                )
        conn.commit()
except Exception:
    pass

try:
    index_path = home / ".codex" / "session_index.jsonl"
    index_path.parent.mkdir(parents=True, exist_ok=True)
    updated_iso = datetime.datetime.fromtimestamp(
        max(updated, 0), datetime.timezone.utc
    ).isoformat().replace("+00:00", "Z")
    index_title = good_title(existing_title) or good_title(title) or good_title(first_user) or directory_title
    entry = {"id": session_id, "thread_name": index_title, "updated_at": updated_iso}

    def index_timestamp(row):
        text = str(row.get("updated_at") or "").strip()
        try:
            if text.endswith("Z"):
                text = text[:-1] + "+00:00"
            return datetime.datetime.fromisoformat(text).timestamp()
        except Exception:
            return 0

    by_id = {}
    if index_path.exists():
        try:
            for raw in index_path.read_text(errors="replace").splitlines():
                try:
                    obj = json.loads(raw)
                except Exception:
                    continue
                row_id = str(obj.get("id") or "")
                if not row_id:
                    continue
                row_title = good_title(obj.get("thread_name") or "")
                if not row_title:
                    continue
                normalized = {
                    "id": row_id,
                    "thread_name": row_title,
                    "updated_at": str(obj.get("updated_at") or ""),
                }
                previous = by_id.get(row_id)
                if previous is None or index_timestamp(normalized) >= index_timestamp(previous):
                    by_id[row_id] = normalized
        except Exception:
            by_id = {}

    by_id[session_id] = entry
    rows = sorted(by_id.values(), key=index_timestamp)
    tmp_path = index_path.with_suffix(index_path.suffix + ".tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        for row in rows:
            handle.write(json.dumps(row, ensure_ascii=False, separators=(",", ":")) + "\n")
    tmp_path.replace(index_path)
except Exception:
    pass
PY
}

codex_register_latest_history_for_dir() {
  local dir="${1:-}"
  local model="${2:-}"
  local effort="${3:-}"
  local title_hint="${4:-}"
  local min_mtime="${5:-0}"
  local attempt latest_id
  [[ -n "$dir" ]] || dir="$(session_start_dir)"
  for attempt in {1..12}; do
    latest_id="$(codex_latest_session_id_for_dir "$dir" "$min_mtime" | head -1)"
    if [[ -n "$latest_id" ]]; then
      codex_mark_history "$latest_id"
      codex_sync_history_record "$latest_id" "$dir" "$model" "$effort" "$title_hint" || true
      printf 'codex_history_id: %s\n' "$latest_id"
      return 0
    fi
    sleep 0.25
  done
  return 1
}

resume_codex_latest_in_dir() {
  local dir model effort current_path pane_text
  model="${1:-}"
  effort="${2:-}"
  dir="$(read_path_arg)"
  if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
    echo "Codex CLI was not found. Expected codex on PATH, Codex.app, or a valid SSHcontroll Codex Path override." >&2
    exit 127
  fi
  if [[ ! -d "$dir" ]]; then
    echo "not a directory: $dir" >&2
    exit 66
  fi
  need_tmux
  if [[ -n "$model" ]]; then
    if ! [[ "$model" =~ '^[A-Za-z0-9._-]+$' ]]; then
      echo "invalid codex model: $model" >&2
      exit 66
    fi
  fi
  if [[ -n "$effort" ]]; then
    case "$effort" in
      none|minimal|low|medium|high|xhigh) ;;
      *)
        echo "invalid codex reasoning effort: $effort" >&2
        exit 66
        ;;
    esac
  fi

  if tmux has-session -t "$CODEX_SESSION" 2>/dev/null; then
    current_path="$(tmux display-message -p -t "$CODEX_SESSION" '#{pane_current_path}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -pJ -t "$CODEX_SESSION" -S -30 2>/dev/null || true)"
    if [[ "$pane_text" == *"Working"* || "$pane_text" == *"esc to interrupt"* || "$pane_text" == *"tab to queue message"* ]]; then
      echo "$CODEX_SESSION is working in ${current_path:-unknown}. Finish or interrupt it before resuming the Codex.app conversation for $dir." >&2
      exit 65
    fi
    tmux kill-session -t "$CODEX_SESSION"
  fi

  local session_id
  session_id="$(codex_latest_session_id_for_dir "$dir" | head -1)"
  if [[ -z "$session_id" ]]; then
    echo "No Codex.app/CLI history was found for $dir. Starting a new shared Codex session instead." >&2
    restart_codex_in_dir "$model" "$effort" <<<"$dir"
    return 0
  fi

  local -a codex_args
  codex_args=("$CODEX_BIN" "resume" "$session_id" "-C" "$dir")
  if [[ -n "$model" ]]; then
    codex_args+=("-m" "$model")
  fi
  if [[ -n "$effort" ]]; then
    codex_args+=("-c" "model_reasoning_effort=\"$effort\"")
  fi
  codex_add_runtime_args_if_needed
  tmux new-session -d -s "$CODEX_SESSION" -c "$dir" "${codex_args[@]}"
  codex_mark_history "$session_id"
  codex_mark_runtime "$(codex_runtime_mode_label)"
  echo "$CODEX_SESSION resumed Codex history $session_id for $dir"
  echo "codex_history_id: $session_id"
}

