codex_queue_enqueue_batch() {
  local model="${1:-}"
  local effort="${2:-}"
  local root payload_file worker
  codex_queue_validate_model_effort "$model" "$effort"
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  payload_file="$(mktemp -t a-cockpit-codex-queue-batch.XXXXXX)"
  cat > "$payload_file"
  python3 - "$root" "$CODEX_SESSION" "$CODEX_HISTORY_ID" "$(session_start_dir)" "$model" "$effort" "$payload_file" <<'PY'
import json
import os
import pathlib
import random
import shutil
import sys
import time

root = pathlib.Path(sys.argv[1])
codex_session = sys.argv[2]
default_history_id = sys.argv[3]
default_dir = sys.argv[4]
model = sys.argv[5]
effort = sys.argv[6]
payload_path = pathlib.Path(sys.argv[7])

try:
    payload = json.loads(payload_path.read_text())
finally:
    try:
        payload_path.unlink()
    except OSError:
        pass

jobs = payload.get("jobs", [])
if not isinstance(jobs, list) or not jobs:
    print("empty codex queue batch", file=sys.stderr)
    raise SystemExit(66)

created = []
for index, job in enumerate(jobs):
    if not isinstance(job, dict):
        continue
    kind = str(job.get("kind") or "send")
    if kind not in {"send", "steer"}:
        print(f"invalid codex queue kind: {kind}", file=sys.stderr)
        raise SystemExit(66)
    prompt = str(job.get("prompt") or "")
    if not prompt.strip():
        print("empty prompt in codex queue batch", file=sys.stderr)
        raise SystemExit(66)
    client_id = str(job.get("clientID") or f"job-{index + 1}")
    directory = str(job.get("directory") or default_dir)
    history_id = str(job.get("historyID") or default_history_id)
    order = str(job.get("order") or f"{int(time.time() * 1000):013d}-{index:04d}")
    job_id = time.strftime("%Y%m%d%H%M%S") + f"-{os.getpid()}-{random.randint(10000, 99999)}-{index + 1:02d}"
    tmp_dir = root / f".tmp-{job_id}"
    job_dir = root / "queued" / job_id
    tmp_dir.mkdir(parents=True, exist_ok=False)
    (tmp_dir / "prompt.txt").write_text(prompt)
    (tmp_dir / "kind").write_text(kind + "\n")
    if kind == "steer":
        (tmp_dir / "is-steer").write_text("")
    (tmp_dir / "model").write_text(model + "\n")
    (tmp_dir / "effort").write_text(effort + "\n")
    (tmp_dir / "history_id").write_text(history_id + "\n")
    (tmp_dir / "dir").write_text(directory + "\n")
    (tmp_dir / "codex_session").write_text(codex_session + "\n")
    (tmp_dir / "created_at").write_text(time.strftime("%Y-%m-%dT%H:%M:%S%z") + "\n")
    (tmp_dir / "order").write_text(order + "\n")
    (tmp_dir / "prompt_bytes").write_text(str(len(prompt.encode())) + "\n")
    shutil.move(str(tmp_dir), str(job_dir))
    created.append((client_id, job_id, kind, len(prompt.encode()), directory, history_id))

for client_id, job_id, kind, prompt_bytes, directory, history_id in created:
    print(f"a_queue_id:{client_id}:{job_id}")
print(f"a_queue_status: queued_on_a")
print(f"a_queue_batch_count: {len(created)}")
PY
  worker="$(codex_queue_worker_session)"
  codex_queue_log "$root" "batch_enqueued count=$(find "$root/queued" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d '[:space:]') codex_session=$CODEX_SESSION"
  codex_queue_worker_start
  printf 'a_queue_worker: %s\n' "$worker"
  printf 'a_queue_dir: %s\n' "$root"
}

codex_queue_promote_steer() {
  local job_id="${1:-}"
  local root job
  if [[ -z "$job_id" || ! "$job_id" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    echo "invalid a_queue_id: $job_id" >&2
    exit 66
  fi
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  job="$root/queued/$job_id"
  if [[ -d "$job" ]]; then
    print -r -- "steer" > "$job/kind"
    : > "$job/is-steer"
    print -r -- "0000000000000-$job_id" > "$job/order"
    print -r -- "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$job/promoted_at"
    codex_queue_log "$root" "promoted_to_steer id=$job_id"
    codex_queue_worker_start
    printf 'a_queue_status: promoted_to_steer\n'
    printf 'a_queue_id: %s\n' "$job_id"
    return 0
  fi
  if [[ -d "$root/processing/$job_id" ]]; then
    printf 'a_queue_status: already_processing\n'
    printf 'a_queue_id: %s\n' "$job_id"
    exit 68
  fi
  if [[ -d "$root/done/$job_id" ]]; then
    printf 'a_queue_status: already_done\n'
    printf 'a_queue_id: %s\n' "$job_id"
    exit 69
  fi
  echo "A queue item not found: $job_id" >&2
  exit 67
}

codex_queue_reorder() {
  local dragged_id="${1:-}"
  local target_id="${2:-}"
  local root id order_index
  local -a jobs ids without_dragged reordered
  if [[ -z "$dragged_id" || ! "$dragged_id" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    echo "invalid dragged a_queue_id: $dragged_id" >&2
    exit 66
  fi
  if [[ -z "$target_id" || ! "$target_id" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    echo "invalid target a_queue_id: $target_id" >&2
    exit 66
  fi
  if [[ "$dragged_id" == "$target_id" ]]; then
    printf 'a_queue_status: unchanged\n'
    printf 'a_queue_id: %s\n' "$dragged_id"
    return 0
  fi
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  if [[ ! -d "$root/queued/$dragged_id" || ! -d "$root/queued/$target_id" ]]; then
    if [[ -d "$root/processing/$dragged_id" || -d "$root/processing/$target_id" ]]; then
      printf 'a_queue_status: already_processing\n'
      exit 68
    fi
    echo "A queue item not found or already delivered." >&2
    exit 67
  fi

  jobs=("${(@f)$(codex_queue_sorted_jobs "$root")}")
  for job in "${jobs[@]}"; do
    id="${job:t}"
    ids+=("$id")
  done
  for id in "${ids[@]}"; do
    [[ "$id" != "$dragged_id" ]] && without_dragged+=("$id")
  done
  for id in "${without_dragged[@]}"; do
    if [[ "$id" == "$target_id" ]]; then
      reordered+=("$dragged_id")
    fi
    reordered+=("$id")
  done

  order_index=0
  for id in "${reordered[@]}"; do
    order_index=$((order_index + 1))
    printf '%08d\n' "$order_index" > "$root/queued/$id/order" 2>/dev/null || true
  done
  codex_queue_log "$root" "reordered dragged=$dragged_id before=$target_id"
  printf 'a_queue_status: reordered\n'
  printf 'a_queue_id: %s\n' "$dragged_id"
}

codex_queue_cancel() {
  local job_id="${1:-}"
  local root job
  if [[ -z "$job_id" || ! "$job_id" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    echo "invalid a_queue_id: $job_id" >&2
