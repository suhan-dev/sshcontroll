codex_queue_resume_all() {
  local base root job session dir started pending_total
  local -a queue_roots jobs processing_jobs
  base="$STATE_DIR/codex-queue"
  if [[ ! -d "$base" ]]; then
    printf 'a_queue_resume: no_queues\n'
    return 0
  fi

  queue_roots=("$base"/*(N/))
  if (( ${#queue_roots} == 0 )); then
    printf 'a_queue_resume: no_queues\n'
    return 0
  fi

  started=0
  pending_total=0
  for root in "${queue_roots[@]}"; do
    codex_queue_prepare_dirs "$root"
    processing_jobs=("$root"/processing/*(N/))
    for job in "${processing_jobs[@]}"; do
      mv "$job" "$root/queued/${job:t}" 2>/dev/null || true
    done

    jobs=("$root"/queued/*(N/))
    pending_total=$((pending_total + ${#jobs}))
    (( ${#jobs} == 0 )) && continue

    session="$(codex_queue_read_file "${jobs[1]}/codex_session")"
    [[ -n "$session" ]] || session="${root:t}"
    dir="$(codex_queue_read_file "${jobs[1]}/dir")"
    [[ -n "$dir" && -d "$dir" ]] || dir="$HOME"

    if A_COCKPIT_CODEX_SESSION="$session" A_COCKPIT_SESSION_DIR="$dir" A_COCKPIT_STATE_DIR="$STATE_DIR" "$SCRIPT_PATH" codex-queue-start >/dev/null 2>&1; then
      started=$((started + 1))
      codex_queue_log "$root" "resume_requested session=$session dir=$dir"
    else
      codex_queue_log "$root" "resume_failed session=$session"
    fi
  done

  printf 'a_queue_resume: started=%s pending=%s\n' "$started" "$pending_total"
}

