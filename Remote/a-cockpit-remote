a_control_app_path() {
  local requested="${1:-}"
  local candidate
  if [[ -n "$requested" ]]; then
    requested="${requested/#\~/$HOME}"
    [[ -d "$requested" ]] && print -r -- "$requested" && return 0
  fi
  for candidate in \
    "$HOME/Desktop/SSHcontroll.app" \
    "$HOME/Applications/SSHcontroll.app" \
    "/Applications/SSHcontroll.app" \
    "$HOME/Desktop/A Control.app" \
    "$HOME/Applications/A Control.app" \
    "/Applications/A Control.app"; do
    [[ -d "$candidate" ]] && print -r -- "$candidate" && return 0
  done
  return 1
}

open_a_control_app() {
  local requested app uid rc open_error
  IFS= read -r requested || requested="${2:-}"
  app="$(a_control_app_path "$requested" 2>/dev/null || true)"
  if [[ -z "$app" ]]; then
    printf 'SSHcontroll.app was not found on A. Install it first, then retry.\n' >&2
    exit 66
  fi

  uid="$(id -u)"
  open_error="$(mktemp -t a-control-open.XXXXXX)"
  set +e
  /usr/bin/open "$app" >/dev/null 2>"$open_error"
  rc=$?
  if [[ "$rc" != "0" && -x /bin/launchctl ]]; then
    /bin/launchctl asuser "$uid" /usr/bin/open "$app" >/dev/null 2>>"$open_error"
    rc=$?
  fi
  set -e
  if [[ "$rc" != "0" ]]; then
    printf 'Could not open SSHcontroll.app through LaunchServices on A.\n' >&2
    if [[ -s "$open_error" ]]; then
      printf 'LaunchServices error:\n' >&2
      sed -n '1,12p' "$open_error" >&2
    fi
    printf 'Do not execute Contents/MacOS/SSHcontroll from SSH/tmux; that is a headless GUI launch and macOS will abort it.\n' >&2
    printf 'Use the logged-in desktop, Screen Sharing, or A-Cockpit Permission Host for GUI launch/QA.\n' >&2
    rm -f "$open_error"
    exit "$rc"
  fi
  rm -f "$open_error"
  cat <<EOF
SSHcontroll.app launch requested through LaunchServices on A.
app: $app

This intentionally does not execute Contents/MacOS/SSHcontroll directly, because direct SSH/tmux GUI launches crash during macOS RegisterApplication.
EOF
}

