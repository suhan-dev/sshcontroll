open_permission_host_app() {
  local uid rc open_error
  local -a open_args
  open_args=()
  if [[ "${1:-}" == "--new" ]]; then
    open_args=(-n)
    shift
  fi
  open_error="$(mktemp -t a-cockpit-permission-host-open.XXXXXX)"
  uid="$(id -u)"
  set +e
  /usr/bin/open "${open_args[@]}" "$PERMISSION_HOST_APP" --args "$@" >/dev/null 2>"$open_error"
  rc=$?
  if [[ "$rc" != "0" ]]; then
    /usr/bin/open "${open_args[@]}" -a "$PERMISSION_HOST_APP" --args "$@" >/dev/null 2>>"$open_error"
  fi
  rc=$?
  if [[ "$rc" != "0" && -x /bin/launchctl ]]; then
    /bin/launchctl asuser "$uid" /usr/bin/open "${open_args[@]}" "$PERMISSION_HOST_APP" --args "$@" >/dev/null 2>>"$open_error"
    rc=$?
  fi
  set -e
  if [[ "$rc" != "0" ]]; then
    printf 'Could not launch A-Cockpit Permission Host through LaunchServices.\n' >&2
    if [[ -s "$open_error" ]]; then
      printf 'LaunchServices error:\n' >&2
      sed -n '1,12p' "$open_error" >&2
    fi
    printf 'Open A once via the logged-in desktop and grant Accessibility/Automation to A-Cockpit Permission Host.\n' >&2
    rm -f "$open_error"
    return "$rc"
  fi
  rm -f "$open_error"
  return 0
}

fan_apply_menu_bar() {
  local requested="$1" deadline result
  install_permission_host_app
  mkdir -p "$PERMISSION_DIR"
  rm -f "$FAN_APPLY_RESULT"

  if ! mfc_is_running; then
    mfc_open_quietly
  fi

  open_permission_host_app --new mfc-preset "$requested" || return 1
  deadline=$((SECONDS + 8))
  while (( SECONDS < deadline )); do
    if [[ -f "$FAN_APPLY_RESULT" ]]; then
      break
    fi
    sleep 0.25
  done

  if [[ ! -f "$FAN_APPLY_RESULT" ]]; then
    printf 'A Fan Setting Not Applied\n'
    printf 'requested: %s\n\n' "$requested"
    printf 'A-Cockpit Permission Host did not return a menu-bar click result.\n'
    printf 'Grant Accessibility to A-Cockpit Permission Host on A, then try again.\n'
    return 1
  fi

  result="$(cat "$FAN_APPLY_RESULT" 2>/dev/null || true)"
  if printf '%s\n' "$result" | grep -q '^ok=1$'; then
    return 0
  fi

  printf 'A Fan Setting Not Applied\n'
  printf 'requested: %s\n\n' "$requested"
  printf '%s\n' "$result" | sed -n 's/^error=//p'
  printf 'Open A > System Settings > Privacy & Security > Accessibility and enable A-Cockpit Permission Host.\n'
  return 1
}

fan_apply_by_restart() {
  local requested="$1" active_preset="$2"
  local actual

  # Macs Fan Control rewrites its preferences on quit. The reliable order is:
  # stop the menu-bar app first, write ActivePreset, then launch it hidden so
  # its normal helper applies the preset. Do not talk to the private SMC helper
  # directly; that can destabilize the app.
  mfc_quit_quietly
  defaults write com.crystalidea.macsfancontrol ActivePreset -string "$active_preset"
  killall cfprefsd >/dev/null 2>&1 || true
  mfc_open_quietly
  sleep 0.8
  actual="$(defaults read com.crystalidea.macsfancontrol ActivePreset 2>/dev/null || true)"

  if [[ "$actual" != "$active_preset" ]]; then
    printf 'warning: Macs Fan Control did not keep the requested preset after reload.\n'
    return 70
  fi
  printf 'Applied by restarting Macs Fan Control quietly in the menu bar.\n'
}

fan_apply() {
  local requested="${1:-}"
  local active_preset custom_index actual_mode expected_mode
  if ! mfc_is_installed; then
    mfc_not_installed_message
    exit 66
  fi

  case "$requested" in
    auto|automatic)
      active_preset="Predefined:0"
      requested="auto"
      expected_mode="auto"
      ;;
    full|fullblast|full-blast)
      active_preset="Predefined:1"
      requested="fullblast"
      expected_mode="fullblast"
      ;;
    3000|4000|5000)
      custom_index="$(mfc_custom_index_for_name "$requested")"
      if [[ -z "$custom_index" ]]; then
        printf 'Macs Fan Control preset "%s" was not found. Create it in Macs Fan Control first.\n' "$requested" >&2
        exit 65
      fi
      active_preset="Custom:$custom_index"
      expected_mode="$requested"
      ;;
    *)
      printf 'usage: fan-apply {auto|fullblast|3000|4000|5000}\n' >&2
      exit 64
      ;;
  esac

  printf 'A Fan Setting Requested\n'
  printf 'requested: %s\n' "$requested"

  if fan_apply_menu_bar "$requested"; then
    sleep 0.8
    actual_mode="$(fan_mode 2>/dev/null || true)"
    if [[ "$actual_mode" != "$expected_mode" ]]; then
      printf 'warning: Macs Fan Control menu click returned, but active mode is %s.\n' "${actual_mode:-unknown}"
      exit 70
    fi
    printf 'A Fan Setting Applied\n'
    printf 'mode: %s\n' "$requested"
    printf '\n'
    printf 'Applied through the Macs Fan Control menu-bar app without restarting it.\n'
    printf 'Fan RPM will refresh separately.\n'
    return 0
  fi

  if [[ "${A_COCKPIT_FAN_RESTART_FALLBACK:-0}" == "1" ]]; then
    printf '\n'
    fan_apply_by_restart "$requested" "$active_preset"
    printf 'Fan RPM will refresh separately.\n'
    return 0
  fi

  printf '\n'
  printf 'Macs Fan Control was left running; no quit/reopen fallback was used.\n'
  printf 'Set A_COCKPIT_FAN_RESTART_FALLBACK=1 only if you prefer the old restart-based fallback.\n'
  exit 70
}

istat_overview_snapshot() {
  local db rows
  db="$HOME/Library/Application Support/iStat Menus 7/history/history.db"
  if ! command -v sqlite3 >/dev/null 2>&1 || [[ ! -f "$db" ]]; then
    return
  fi

  rows="$(sqlite3 "$db" "
    with latest_cpu as (
      select max(time) as t
      from cpu
      where interval = 5
    )
    select 'CPU: user ' || printf('%.1f', user) || '%, system ' ||
           printf('%.1f', system) || '%, idle ' ||
           printf('%.1f', max(0, 100.0 - user - system)) || '%'
    from cpu, latest_cpu
    where cpu.time = latest_cpu.t
      and cpu.interval = 5
    limit 1;

    with latest_gpu as (
      select max(time) as t
      from gpu
      where interval = 5
    )
    select 'GPU: processor ' ||
           printf('%.1f', processor) || '%, memory ' ||
           printf('%.1f', memory) || '%'
    from gpu, latest_gpu
    where gpu.time = latest_gpu.t
      and gpu.interval = 5
    order by key
    limit 4;

    with latest_memory as (
      select max(time) as t
      from memory
      where interval = 5
    )
    select 'Memory: pressure ' || printf('%.1f', pressure) || '%, app ' ||
           printf('%.1f', app / 1024.0) || 'GB, wired ' ||
           printf('%.1f', wired / 1024.0) || 'GB, compressed ' ||
           printf('%.1f', compressed / 1024.0) || 'GB, total ' ||
           printf('%.0f', total / 1024.0) || 'GB'
    from memory, latest_memory
    where memory.time = latest_memory.t
      and memory.interval = 5
    limit 1;

    with latest_network as (
      select max(time) as t
      from network
      where interval = 5
    ),
    active_network as (
      select upload, download
      from network, latest_network
      where network.time = latest_network.t
        and network.interval = 5
      order by upload + download desc
      limit 1
    )
    select 'Network: up ' ||
           case when upload >= 1024 then printf('%.1f MB/s', upload / 1024.0)
                else printf('%.1f KB/s', upload) end ||
           ', down ' ||
           case when download >= 1024 then printf('%.1f MB/s', download / 1024.0)
                else printf('%.1f KB/s', download) end
    from active_network;
  " 2>/dev/null || true)"

  if [[ -n "$rows" ]]; then
    printf '%s\n' "$rows"
  fi
}

istat_metric_snapshot() {
