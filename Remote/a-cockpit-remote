write_file() {
  local file_path dir base tmp mode
  file_path="$(read_path_arg)"
  if [[ -e "$file_path" && ! -f "$file_path" && ! -L "$file_path" ]]; then
    echo "not a writable file: $file_path" >&2
    exit 66
  fi
  dir="${file_path:h}"
  base="${file_path:t}"
  if [[ ! -d "$dir" ]]; then
    mkdir -p -- "$dir"
  fi
  if [[ -L "$file_path" ]]; then
    cat > "$file_path"
    exit 0
  fi
  tmp="$(mktemp "$dir/.a-cockpit-${base}.XXXXXX")"
  cat > "$tmp"
  if [[ -f "$file_path" ]]; then
    mode="$(stat -f %Lp "$file_path" 2>/dev/null || true)"
    if [[ -n "$mode" ]]; then
      chmod "$mode" "$tmp" 2>/dev/null || true
    fi
  fi
  mv "$tmp" "$file_path"
}

install_uploaded_file() {
  local tmp_path file_path dir mode
  tmp_path="$(read_path_arg)"
  file_path="$(read_path_arg)"
  if [[ ! -f "$tmp_path" && ! -L "$tmp_path" ]]; then
    echo "uploaded temp file not found: $tmp_path" >&2
    exit 66
  fi
  if [[ -e "$file_path" && ! -f "$file_path" && ! -L "$file_path" ]]; then
    echo "not a writable file: $file_path" >&2
    exit 66
  fi
  dir="${file_path:h}"
  if [[ ! -d "$dir" ]]; then
    mkdir -p -- "$dir"
  fi
  if [[ -L "$file_path" ]]; then
    cat -- "$tmp_path" > "$file_path"
    rm -f -- "$tmp_path"
    printf 'Saved: %s\n' "$file_path"
    return 0
  fi
  if [[ -f "$file_path" ]]; then
    mode="$(stat -f %Lp "$file_path" 2>/dev/null || true)"
    if [[ -n "$mode" ]]; then
      chmod "$mode" "$tmp_path" 2>/dev/null || true
    fi
  fi
  mv -- "$tmp_path" "$file_path"
  printf 'Saved: %s\n' "$file_path"
}

