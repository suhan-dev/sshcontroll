    exit 66
  fi
  if [[ -z "$team" ]]; then
    printf 'Apple Development Team ID is missing. Add it in SSHcontroll Settings > Apple Signing.\n' >&2
    exit 64
  fi
  bundle_arg=()
  if [[ -n "$bundle" ]]; then
    bundle_arg=(PRODUCT_BUNDLE_IDENTIFIER="$bundle")
  fi
  set +e
  output="$(cd "$repo" && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer xcodebuild \
    -project ios/Runner.xcodeproj \
    -scheme Runner \
    -configuration Debug \
    -sdk iphoneos \
    -destination 'generic/platform=iOS' \
    -allowProvisioningUpdates \
    CODE_SIGN_STYLE=Automatic \
    DEVELOPMENT_TEAM="$team" \
    "${bundle_arg[@]}" \
    build 2>&1)"
  rc=$?
  set -e
  printf '%s\n' "$output" |
    grep -Ei 'error:|warning:|Signing|provision|profile|account|certificate|team|requires|No profiles|No Accounts|BUILD FAILED|BUILD SUCCEEDED' |
    tail -160 || true
  printf '\nexit=%s\n' "$rc"
