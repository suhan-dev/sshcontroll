                    continue
                if obj.get("type") == "session_meta":
                    meta = obj.get("payload") or {}
                    continue
                payload = obj.get("payload") or {}
                if obj.get("type") == "response_item":
                    item = payload.get("item")
                    source = item if isinstance(item, dict) else payload
                    role = (source.get("role") or payload.get("role") or "").lower()
                    kind = (source.get("type") or payload.get("type") or "").lower()
                    if role == "user" or kind in ("user_message", "input_text"):
                        text = item_text_for_title(source) or item_text_for_title(payload)
                        if text and not first_user_title:
                            first_user_title = good_title(text)
                elif obj.get("type") == "event_msg":
                    message = payload.get("message") or ""
                    event_title = good_title(message)
                    if event_title and not title:
                        title = event_title
    except Exception:
