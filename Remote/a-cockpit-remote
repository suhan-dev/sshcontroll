codex_token_status() {
  local model="${1:-}"
  local effort="${2:-}"
  local dir token_session attempt status_attempt pane_text lower current_path cache_age
  dir="$(read_path_arg)"
  [[ -z "$dir" ]] && dir="$(session_start_dir)"
  [[ -d "$dir" ]] || dir="$HOME"
  need_tmux
  if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
    echo "Codex CLI was not found. Expected codex on PATH, Codex.app, or a valid SSHcontroll Codex Path override." >&2
    exit 127
  fi
  if [[ -n "$model" ]]; then
    if ! [[ "$model" =~ '^[A-Za-z0-9._-]+$' ]]; then
      echo "invalid codex model: $model" >&2
      exit 66
    fi
  fi
  if [[ -n "$effort" ]]; then
    case "$effort" in
      none|minimal|low|medium|high|xhigh) ;;
      *)
        echo "invalid codex reasoning effort: $effort" >&2
        exit 66
        ;;
    esac
  fi

  local -a codex_args
  codex_args=("$CODEX_BIN" "--no-alt-screen")
  [[ -n "$model" ]] && codex_args+=("-m" "$model")
  [[ -n "$effort" ]] && codex_args+=("-c" "model_reasoning_effort=\"$effort\"")

  token_session="$CODEX_TOKEN_STATUS_SESSION"
  tmux list-sessions -F '#{session_name}' 2>/dev/null |
    while IFS= read -r stale_session; do
      case "$stale_session" in
        a-control-token-status-[0-9]*)
          tmux kill-session -t "$stale_session" 2>/dev/null || true
          ;;
      esac
    done

  if tmux has-session -t "$token_session" 2>/dev/null; then
    current_path="$(tmux display-message -p -t "$token_session" '#{pane_current_path}' 2>/dev/null || true)"
    pane_text="$(tmux capture-pane -pJ -t "$token_session" -S -30 2>/dev/null || true)"
    lower="$(print -r -- "$pane_text" | tr '[:upper:]' '[:lower:]')"
    if [[ "$lower" == *"panic"* || "$lower" == *"error:"* || "$lower" == *"exited"* ]]; then
      tmux kill-session -t "$token_session" 2>/dev/null || true
    fi
  fi

  if ! tmux has-session -t "$token_session" 2>/dev/null; then
    tmux new-session -d -s "$token_session" -c "$dir" "${codex_args[@]}"
  fi

  for attempt in {1..45}; do
    pane_text="$(tmux capture-pane -pJ -t "$token_session" -S -90 2>/dev/null || true)"
    lower="$(print -r -- "$pane_text" | tr '[:upper:]' '[:lower:]')"
    if [[ "$pane_text" == *"›"* || "$lower" == *"model:"* || "$lower" == *"directory:"* ]]; then
      break
    fi
    sleep 0.18
  done

  for status_attempt in {1..3}; do
    tmux send-keys -t "$token_session" Escape C-u 2>/dev/null || true
    sleep 0.04
    tmux send-keys -t "$token_session" -l "/status"
    sleep 0.05
    tmux send-keys -t "$token_session" Enter
    sleep 2.4
    pane_text="$(capture_session "$token_session" 2>/dev/null || true)"
    lower="$(print -r -- "$pane_text" | tr '[:upper:]' '[:lower:]')"
    if [[ "$lower" == *"weekly limit:"* || "$lower" == *"less than"* ]]; then
      print -r -- "$pane_text" > "$CODEX_TOKEN_STATUS_CACHE" 2>/dev/null || true
      print -r -- "$pane_text"
      return 0
    fi
    if [[ "$lower" == *"refresh requested"* ]]; then
      sleep 3.2
    fi
  done

  if [[ -s "$CODEX_TOKEN_STATUS_CACHE" ]]; then
    cache_age=$(( $(date +%s) - $(stat -f %m "$CODEX_TOKEN_STATUS_CACHE" 2>/dev/null || echo 0) ))
    if [[ "$cache_age" -lt 14400 ]]; then
      cat "$CODEX_TOKEN_STATUS_CACHE"
      return 0
    fi
  fi
  print -r -- "$pane_text"
  return 70
}

