  worker_state="$(codex_queue_worker_state "$root" "$worker")"
  heartbeat_age="$(codex_queue_worker_heartbeat_age "$root")"
  printf 'a_queue_status: %s\n' "$worker_state"
  printf 'queued: %s\n' "$queued"
