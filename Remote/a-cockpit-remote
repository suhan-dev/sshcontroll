records = []
for path in base.glob("**/*.jsonl"):
    try:
        stat = path.stat()
    except OSError:
        continue
    meta = {}
    title = ""
    first_user_title = ""
    try:
        with path.open(errors="replace") as handle:
            for line in handle:
                try:
