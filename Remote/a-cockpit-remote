codex_history_json() {
  local dir
  if ! IFS= read -r dir; then
    dir=""
  fi
  if [[ "$dir" == \~ ]]; then
    dir="$HOME"
  elif [[ "$dir" == \~/* ]]; then
    dir="$HOME/${dir#\~/}"
  fi
  [[ -z "$dir" ]] && dir="$(session_start_dir)"
  local cache_dir cache_key cache_file cache_mtime cache_age tmp_file
  cache_dir="$HOME/.cache/sshcontroll"
  mkdir -p -- "$cache_dir" 2>/dev/null || true
  cache_key="$(printf '%s' "$dir" | shasum -a 1 | awk '{print $1}')"
  cache_file="$cache_dir/codex-history-${cache_key}.json"
  if [[ -z "${A_COCKPIT_CODEX_HISTORY_FORCE:-}" && -s "$cache_file" ]]; then
    cache_mtime="$(stat -f %m "$cache_file" 2>/dev/null || echo 0)"
    cache_age=$(( $(date +%s) - cache_mtime ))
    if (( cache_age >= 0 && cache_age <= 6 )); then
      cat "$cache_file"
      return 0
    fi
  fi
  tmp_file="$(mktemp "${TMPDIR:-/tmp}/sshcontroll-codex-history.XXXXXX")" || exit 74
  if python3 - "$dir" >"$tmp_file" <<'PY'
import json
import datetime
import os
import pathlib
import re
import sqlite3
import sys

target = pathlib.Path(sys.argv[1]).expanduser()
try:
    target = target.resolve()
except Exception:
    pass
host = str(os.environ.get("A_COCKPIT_CODEX_HISTORY_HOST") or "remote").strip().lower() or "remote"

base = pathlib.Path.home() / ".codex" / "sessions"
sqlite_titles = {}
sqlite_paths = {}
sqlite_meta = {}
sqlite_records = []
state_db = pathlib.Path.home() / ".codex" / "state_5.sqlite"
index_path = pathlib.Path.home() / ".codex" / "session_index.jsonl"
index_titles = {}
index_times = {}

def good_title(value):
    clean = " ".join(str(value or "").split())
    if not clean or clean == "Codex session":
        return ""
    lower = clean.lower()
    blocked_fragments = (
        "<environment_context", "</environment_context", "<current_date>",
        "<timezone>", "<shell>", "<cwd>", "rollout_path=", "thread_id=",
        "memory-summary.md", "memory_summary.md", "chronicle synthetic",
            "computer use is installed, but blocked",
            "apple event error",
            "could not create image from display",
            "codex/tcc relevant processes",
            "local.codex.cli-permission-host",
            "ktccserviceappleevents",
            "png image data,",
            '{"output":',
            '"metadata":',
            '"exit_code":',
            "subagent_notification",
            "a_queue_",
            "process running with session id",
            "steer the current codex work with this instruction",
            "basename:",
            "first line:",
            "smoke-test marker",
            "[@computer]",
        )
    if any(fragment in lower for fragment in blocked_fragments):
        return ""
    if re.match(r"^(cd(?:\s|$)|pwd(?:\s|$)|ls(?:\s|$)|clear$|/(status|model|permissions)\b)", clean, re.I):
        return ""
    if re.match(r"^Stage\s+\d+\b.*\brole:", clean, re.I):
        return ""
    code_tokens = (
        "def ", "class ", "struct ", "enum ", "func ", "return ", "self.", "this.",
        " = ", " -> ", "import ", "from ", "@override", "private ", "public ",
    )
    if clean.count("\n") or any(token in lower for token in code_tokens):
        return ""
    if len(clean) > 120:
        return ""
    return clean

def text_from_content_for_title(content):
    pieces = []
    if isinstance(content, str):
        pieces.append(content)
    elif isinstance(content, list):
        for item in content:
            if isinstance(item, str):
                pieces.append(item)
            elif isinstance(item, dict):
                for key in ("text", "input_text", "output_text", "content", "message"):
                    value = item.get(key)
                    if isinstance(value, str) and value.strip():
                        pieces.append(value)
                        break
                    if isinstance(value, (list, dict)):
                        nested = text_from_content_for_title(value)
                        if nested:
                            pieces.append(nested)
                            break
    elif isinstance(content, dict):
        for key in ("text", "input_text", "output_text", "content", "message"):
            value = content.get(key)
            if isinstance(value, str) and value.strip():
                pieces.append(value)
                break
            if isinstance(value, (list, dict)):
                nested = text_from_content_for_title(value)
                if nested:
                    pieces.append(nested)
                    break
    return "\n".join(pieces).strip()

def item_text_for_title(payload):
    if not isinstance(payload, dict):
        return ""
    for key in ("content", "message", "text", "input", "output"):
        text = text_from_content_for_title(payload.get(key))
        if text:
            return text
    return ""

def parse_index_time(value):
    text = str(value or "").strip()
    if not text:
        return 0
    try:
        if text.endswith("Z"):
            text = text[:-1] + "+00:00"
        return int(datetime.datetime.fromisoformat(text).timestamp())
    except Exception:
        return 0

def normalized_path(value):
    text = str(value or "").strip()
    if not text:
        return None
    try:
        return pathlib.Path(text).expanduser().resolve()
    except Exception:
        return pathlib.Path(text).expanduser()

def path_is_relative_to(path, parent):
    try:
        path.relative_to(parent)
        return True
    except Exception:
        return False

def path_matches_target(value):
    path = normalized_path(value)
    if path is None:
        return False
    return str(path) == str(target) or path_is_relative_to(path, target)

if index_path.exists():
    try:
        with index_path.open(errors="replace") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except Exception:
