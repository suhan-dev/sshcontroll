codex_queue_fail_job() {
  local root="$1"
  local job="$2"
  local message="$3"
  local job_id="${job:t}"
  print -r -- "$message" >> "$job/worker.log" 2>/dev/null || true
  print -r -- "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$job/failed_at" 2>/dev/null || true
  mkdir -p "$root/failed"
  mv "$job" "$root/failed/$job_id" 2>/dev/null || true
  codex_queue_log "$root" "failed id=$job_id $message"
}

codex_queue_worker() {
  local root idle_ticks job job_id job_kind model effort history_id dir pane_text busy interactive result acq_job_is_steer acq_sent_kind prompt_hint latest_history
  local -a queued_jobs
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  need_tmux
  idle_ticks=0
  codex_queue_log "$root" "worker_loop_started codex_session=$CODEX_SESSION"
  while true; do
    codex_queue_touch_worker_heartbeat "$root"
    queued_jobs=("${(@f)$(codex_queue_worker_jobs "$root")}")
    queued_jobs=("${(@)queued_jobs:#}")
    if (( ${#queued_jobs} == 0 )); then
      idle_ticks=$((idle_ticks + 1))
      if (( idle_ticks >= 1200 )); then
        codex_queue_log "$root" "worker_idle_exit"
        return 0
      fi
      sleep 3
      continue
    fi
    idle_ticks=0
    job="${queued_jobs[1]}"
    [[ -n "$job" ]] || { sleep 1; continue; }
    job_id="${job:t}"
    acq_job_is_steer=0
    if [[ -f "$job/is-steer" ]]; then
      acq_job_is_steer=1
      job_kind="steer"
    else
      job_kind="$(codex_queue_read_file "$job/kind")"
      [[ -n "$job_kind" ]] || job_kind="send"
    fi
    model="$(codex_queue_read_file "$job/model")"
    effort="$(codex_queue_read_file "$job/effort")"
    history_id="$(codex_queue_read_file "$job/history_id")"
    dir="$(codex_queue_read_file "$job/dir")"
    [[ -n "$dir" ]] || dir="$(session_start_dir)"
    codex_queue_log "$root" "processing id=$job_id kind=$job_kind is_steer=$acq_job_is_steer history=${history_id:-none} dir=$dir"

    pane_text=""
    busy=0
    interactive=0
    if tmux has-session -t "$CODEX_SESSION" 2>/dev/null; then
      pane_text="$(codex_queue_pane_text "$CODEX_SESSION")"
      codex_queue_pane_is_interactive "$pane_text" && interactive=1
      codex_queue_pane_is_busy "$pane_text" && busy=1
    fi
    if [[ "$interactive" == "1" ]]; then
      codex_queue_log "$root" "waiting_interactive_choice id=$job_id"
      sleep 5
      continue
    fi
    if [[ "$acq_job_is_steer" != "1" && "$busy" == "1" ]]; then
      sleep 2
      continue
    fi

    if ! mv "$job" "$root/processing/$job_id" 2>/dev/null; then
      sleep 0.2
      continue
    fi
    job="$root/processing/$job_id"
    if [[ ! -s "$job/prompt.txt" ]]; then
      codex_queue_fail_job "$root" "$job" "empty_prompt"
      continue
    fi

    if [[ "$acq_job_is_steer" != "1" || "$busy" != "1" ]]; then
      if ! ( print -r -- "$dir" | ensure_codex_for_prompt "$model" "$effort" "$history_id" ) >> "$job/worker.log" 2>&1; then
        codex_queue_fail_job "$root" "$job" "ensure_codex_failed"
        continue
      fi
    fi

    pane_text="$(codex_queue_pane_text "$CODEX_SESSION")"
    if codex_queue_pane_is_interactive "$pane_text"; then
      mv "$job" "$root/queued/$job_id" 2>/dev/null || true
      codex_queue_log "$root" "requeued_interactive_choice id=$job_id"
      sleep 5
      continue
    fi
    if [[ "$acq_job_is_steer" != "1" ]] && codex_queue_pane_is_busy "$pane_text"; then
      mv "$job" "$root/queued/$job_id" 2>/dev/null || true
      sleep 2
      continue
    fi

    local send_epoch
    send_epoch="$(date +%s)"
    if [[ "$acq_job_is_steer" == "1" ]]; then
      if ( cat "$job/prompt.txt" | steer_codex ) >> "$job/worker.log" 2>&1; then
        result=0
      else
        result=$?
      fi
    else
      if ( cat "$job/prompt.txt" | paste_stdin_and_enter "$CODEX_SESSION" codex queue ) >> "$job/worker.log" 2>&1; then
        result=0
      else
        result=$?
      fi
    fi
    if [[ "$result" == "0" ]]; then
      if [[ "$acq_job_is_steer" != "1" ]]; then
        codex_queue_wait_for_send_ack "$CODEX_SESSION" >> "$job/worker.log" 2>&1 || true
        prompt_hint="$(LC_ALL=C head -c 360 "$job/prompt.txt" 2>/dev/null | tr '\n' ' ' || true)"
        codex_register_latest_history_for_dir "$dir" "$model" "$effort" "$prompt_hint" "$((send_epoch - 1))" >> "$job/worker.log" 2>&1 || true
        latest_history="$(codex_current_history_marker)"
        [[ -n "$latest_history" ]] && print -r -- "$latest_history" > "$job/history_id" 2>/dev/null || true
      fi
      print -r -- "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$job/sent_at"
      mkdir -p "$root/done"
      mv "$job" "$root/done/$job_id" 2>/dev/null || true
      acq_sent_kind="send"
      [[ "$acq_job_is_steer" == "1" ]] && acq_sent_kind="steer"
      codex_queue_log "$root" "sent id=$job_id kind=$acq_sent_kind"
    else
      codex_queue_fail_job "$root" "$job" "send_failed exit=$result"
    fi
    sleep 0.8
  done
}

