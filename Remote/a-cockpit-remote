fan_rpm_measure_native_5s() {
  local tmp_file out_file sample direct measured_at
  tmp_file="$(mktemp -t a-cockpit-fan-rpm.XXXXXX)"
  out_file="$(mktemp -t a-cockpit-fan-rpm-out.XXXXXX)"
  measured_at="$(date '+%Y-%m-%d %H:%M:%S')"

  {
    printf 'A Fan RPM  %s\n\n' "$measured_at"
    printf '%s\n' 'Sample window: 5 sec'
    printf 'Measured at: %s\n' "$measured_at"
  } > "$out_file"

  for sample in 1 2 3 4 5; do
    if command -v a-cockpit-smc-rpm >/dev/null 2>&1; then
      direct="$(a-cockpit-smc-rpm 2>/dev/null || true)"
      if [[ -n "$direct" ]]; then
        printf '%s\n' "$direct" >> "$tmp_file"
      fi
    fi
    if [[ "$sample" != "5" ]]; then
      sleep 1
    fi
  done

  if [[ -s "$tmp_file" ]]; then
    /usr/bin/python3 - "$tmp_file" >> "$out_file" <<'PY'
import collections
import re
import statistics
import sys

path = sys.argv[1]
values = collections.defaultdict(list)
with open(path, "r", encoding="utf-8", errors="replace") as handle:
    for line in handle:
        match = re.search(r"Fan\s+(\d+)\s+(?:direct|actual):\s*([0-9.]+)\s*rpm", line, re.I)
        if match:
            values[int(match.group(1))].append(float(match.group(2)))

for fan in sorted(values):
    readings = values[fan]
    if not readings:
        continue
    avg = statistics.fmean(readings)
    print(
        f"Fan {fan} measured: avg {avg:.0f} rpm "
        f"(last {readings[-1]:.0f}, min {min(readings):.0f}, max {max(readings):.0f}, samples {len(readings)})"
    )
PY
    printf '%s\n' 'Source: macOS native SMC direct read' >> "$out_file"
  else
    printf '%s\n' 'Fan RPM unavailable: macOS native SMC did not report fan RPM during 5 sec' >> "$out_file"
    printf '%s\n' 'Source: macOS native SMC direct read' >> "$out_file"
    printf '%s\n' 'Note: powermetrics/ioreg also did not expose fan RPM on this Mac.' >> "$out_file"
  fi

  mkdir -p "$STATE_DIR"
  cp "$out_file" "$FAN_RPM_CACHE"
  cat "$out_file"
  rm -f "$tmp_file" "$out_file"
}

