        try:
            if not os.path.islink(path):
                keep.append(name)
        except OSError:
            pass
    dirnames[:] = keep

    for name in filenames:
        path = os.path.join(current, name)
        try:
            st = os.lstat(path)
        except OSError:
            continue
        if os.path.islink(path):
            continue
        files += 1
        total += st.st_size

print(json.dumps({"bytes": total, "files": files, "dirs": dirs}, separators=(",", ":")))
PY
}

