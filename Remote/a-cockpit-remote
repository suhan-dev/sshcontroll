wait_for_codex_input_ready() {
  local target="$1"
  local attempt
  local pane_text
  local bottom_text
  local lower
  for attempt in {1..50}; do
    pane_text="$(tmux capture-pane -pJ -t "$target" -S -50 2>/dev/null || true)"
    bottom_text="$(print -r -- "$pane_text" | tail -24)"
    lower="$(print -r -- "$bottom_text" | tr '[:upper:]' '[:lower:]')"
    if [[ "$lower" == *"do you trust the contents of this directory"* || "$lower" == *"press enter to continue"* ]]; then
      tmux send-keys -t "$target" Enter 2>/dev/null || true
      sleep 0.6
      continue
    fi
    if [[ "$lower" == *"working"* || "$lower" == *"esc to interrupt"* || "$lower" == *"tab to queue message"* ]]; then
      return 0
    fi
    if [[ "$bottom_text" == *"›"* || "$lower" == *"model:"* || "$lower" == *"directory:"* ]]; then
      return 0
    fi
    sleep 0.12
  done
  return 1
}

paste_stdin_and_enter() {
  local target="$1"
  local mode="${2:-normal}"
  local submit_mode="${3:-auto}"
  local tmp_file
  local buffer_name
  local first_char
  local pane_text
  local busy
  local byte_count
  local text
  need_tmux
  if ! tmux has-session -t "$target" 2>/dev/null; then
    echo "SSHcontroll ${mode} runtime is not started for session $target." >&2
    exit 65
  fi
  tmp_file="$(mktemp -t a-cockpit-buffer.XXXXXX)"
  buffer_name="a-cockpit-$$-$RANDOM"
  cat > "$tmp_file"
  first_char="$(LC_ALL=C head -c 1 "$tmp_file" 2>/dev/null || true)"

  busy=0
  if [[ "$mode" == "codex" ]]; then
    pane_text="$(tmux capture-pane -pJ -t "$target" -S -30 2>/dev/null || true)"
    if [[ "$pane_text" == *"Approaching rate limits"* || "$pane_text" == *"Press enter to confirm or esc to go back"* || "$pane_text" == *"Switch to gpt-"* || "$pane_text" == *"Do you trust the contents of this directory"* ]]; then
      rm -f "$tmp_file"
      echo "Codex is showing an interactive choice. Pick an option in the live Codex terminal first, then send again." >&2
      exit 65
    fi
    if [[ "$pane_text" == *"Working"* || "$pane_text" == *"esc to interrupt"* || "$pane_text" == *"tab to queue message"* ]]; then
      busy=1
    fi
  fi

  if [[ "$mode" == "codex" && "$busy" == "1" && "$first_char" == "/" ]]; then
    rm -f "$tmp_file"
    echo "Codex is working. Slash commands cannot be queued; wait for the current turn, then send it again." >&2
    exit 65
  fi

  if [[ "$mode" == "codex" && "$busy" != "1" && "$submit_mode" != "steer" ]]; then
    if ! wait_for_codex_input_ready "$target"; then
      rm -f "$tmp_file"
      echo "Codex input was not ready for session $target. The prompt was not pasted." >&2
      exit 70
    fi
  fi

  if { [[ "$mode" == "codex" && "$busy" != "1" && "$submit_mode" != "steer" ]]; } || [[ "$mode" == "claude" ]]; then
    tmux send-keys -t "$target" Escape C-u 2>/dev/null || true
    sleep 0.04
  fi

  if [[ "$mode" == "codex" || "$mode" == "claude" ]]; then
    tmux load-buffer -b "$buffer_name" "$tmp_file"
    tmux paste-buffer -p -r -b "$buffer_name" -t "$target"
  else
    tmux send-keys -t "$target" C-u 2>/dev/null || true
    sleep 0.03
    tmux load-buffer -b "$buffer_name" "$tmp_file"
    tmux paste-buffer -p -r -b "$buffer_name" -t "$target"
  fi

  if [[ "$mode" == "codex" && "$busy" == "1" && "$submit_mode" == "queue" ]]; then
    sleep 0.05
    tmux send-keys -t "$target" Tab
    echo "queued"
  elif [[ "$mode" == "codex" && "$busy" == "1" && "$submit_mode" == "steer" ]]; then
    sleep 0.05
    tmux send-keys -t "$target" Enter
    echo "steered"
  else
    sleep 0.05
    tmux send-keys -t "$target" Enter
  fi
  if [[ "$mode" == "codex" && "$busy" != "1" && "$first_char" == "/" ]]; then
    sleep 0.15
    tmux send-keys -t "$target" Enter
  fi
  tmux delete-buffer -b "$buffer_name" 2>/dev/null || true

  rm -f "$tmp_file"
}

