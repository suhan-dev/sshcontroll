resolve_file() {
  local candidate cwd context
  candidate="$(read_path_arg)"
  cwd="$(read_path_arg || true)"
  context="$(cat || true)"
  [[ -z "$cwd" ]] && cwd="$PWD"
  python3 - "$candidate" "$cwd" "$context" <<'PY'
import os
import pathlib
import sys

candidate = pathlib.Path(sys.argv[1]).expanduser()
cwd = pathlib.Path(sys.argv[2]).expanduser()
context = sys.argv[3] if len(sys.argv) > 3 else ""

def emit(path):
    print(str(path))
    raise SystemExit(0)

if candidate.is_file() or candidate.is_symlink():
    emit(candidate)

if not candidate.is_absolute():
    joined = cwd / candidate
    if joined.is_file() or joined.is_symlink():
        emit(joined)

name = candidate.name
if not name or any(ch in name for ch in "*?[]{}$"):
    print(f"not found: {candidate}", file=sys.stderr)
    raise SystemExit(66)

roots = []
context_roots = []
home = pathlib.Path.home()
relative_candidate = None if candidate.is_absolute() else candidate
for token in context.replace("`", " ").replace('"', " ").replace("'", " ").split():
    token = token.strip(",:;()[]{}<>")
    if not (token.startswith("~/") or token.startswith("/Users/") or token.startswith("/private/tmp") or token.startswith("/tmp")):
        continue
    expanded = pathlib.Path(token).expanduser()
    if expanded.is_file() or expanded.is_symlink():
        roots.append(expanded.parent)
        context_roots.append(expanded.parent)
    elif expanded.is_dir():
        roots.append(expanded)
        context_roots.append(expanded)
for root in (
    cwd,
    cwd / "figures",
    cwd / "report",
    cwd / "reports",
    cwd / "research_reports",
    cwd.parent,
    home / "Desktop",
    home / "Desktop" / "code",
    home / "Documents",
    home / "Downloads",
    home / "remote",
    home / "remote" / "app",
):
    try:
        root = root.resolve()
    except OSError:
        continue
    if root.is_dir() and root not in roots:
        roots.append(root)

if relative_candidate is not None:
    for root in roots:
        joined = root / relative_candidate
        if joined.is_file() or joined.is_symlink():
            emit(joined)

matches = []
max_dirs = 5000
visited_dirs = 0
skip_dirs = {
    ".git",
    ".gradle",
    ".dart_tool",
    ".mypy_cache",
    ".pytest_cache",
    ".tox",
    ".venv",
    ".swiftpm",
    "DerivedData",
    "Pods",
    "node_modules",
    "__pycache__",
    "venv",
}
candidate_parts = [part.lower() for part in candidate.parts if part not in (candidate.anchor, "/", "")]
candidate_suffixes = []
for count in range(min(5, len(candidate_parts)), 0, -1):
    candidate_suffixes.append(candidate_parts[-count:])

def suffix_score(path):
    parts = [part.lower() for part in path.parts if part not in (path.anchor, "/", "")]
    context_bonus = 0
    suffix_best = 0
    for context_root in context_roots:
        try:
            path.relative_to(context_root)
            context_bonus = 420
            break
        except Exception:
            pass
    for suffix in candidate_suffixes:
        if len(parts) >= len(suffix) and parts[-len(suffix):] == suffix:
            suffix_best = max(suffix_best, len(suffix) * 100)
    best = context_bonus + suffix_best
    parent_names = set(candidate_parts[:-1])
    if parent_names:
        best += min(40, 5 * len(parent_names.intersection(parts[:-1])))
    try:
        rel = path.relative_to(cwd)
        best += 80
        if len(rel.parts) <= 3:
            best += 40
    except Exception:
        pass
    return best

for root in roots:
    for dirpath, dirnames, filenames in os.walk(root):
        visited_dirs += 1
        dirnames[:] = [
            d for d in dirnames
            if d not in skip_dirs and not d.startswith(".cache")
        ]
        if name in filenames:
            path = pathlib.Path(dirpath) / name
            try:
                stat = path.stat()
                matches.append((suffix_score(path), stat.st_mtime, path))
            except OSError:
                matches.append((suffix_score(path), 0, path))
        if visited_dirs >= max_dirs:
            break
        relative = pathlib.Path(dirpath).relative_to(root)
        if str(relative) != "." and len(relative.parts) > 8:
            dirnames[:] = []
    if visited_dirs >= max_dirs:
        break

if matches:
    matches.sort(key=lambda item: (item[0], item[1]), reverse=True)
    emit(matches[0][2])

print(f"not found: {candidate}", file=sys.stderr)
raise SystemExit(66)
PY
}

