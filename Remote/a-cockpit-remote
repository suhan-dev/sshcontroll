  local seconds="\$2"
  local pid ticks i rc
  shift 2
  "\$@" >/dev/null 2>&1 &
  pid="\$!"
  ticks=\$(( seconds * 5 ))
  i=0
  while (( i < ticks )); do
    if ! kill -0 "\$pid" >/dev/null 2>&1; then
      wait "\$pid"
      rc="\$?"
      echo "\$name=\$rc"
      return 0
    fi
    sleep 0.2
    i=\$(( i + 1 ))
  done
  kill "\$pid" >/dev/null 2>&1 || true
  wait "\$pid" >/dev/null 2>&1 || true
  echo "\$name=timeout"
}
