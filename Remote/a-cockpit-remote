apple_signing_test() {
  local values repo team bundle output rc
  local -a bundle_arg
  values="$(read_apple_signing_input)"
  repo="$(printf '%s\n' "$values" | sed -n '1p')"
  team="$(printf '%s\n' "$values" | sed -n '2p')"
  bundle="$(printf '%s\n' "$values" | sed -n '3p')"
