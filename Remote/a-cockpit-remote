    session_id = meta.get("id") or path.stem.split("-")[-1]
    meta_thread_source = str(meta.get("thread_source") or "")
    meta_source_value = meta.get("source")
    meta_source = meta_source_value if isinstance(meta_source_value, str) else json.dumps(meta_source_value or "", ensure_ascii=False)
    if meta_thread_source.lower() == "subagent" or "subagent" in meta_source.lower():
