}

codex_queue_worker_heartbeat_age() {
  local root="$1"
  local heartbeat_file stamp now
  heartbeat_file="$(codex_queue_worker_heartbeat_file "$root")"
  [[ -s "$heartbeat_file" ]] || { print -r -- "999999"; return 0; }
  stamp="$(LC_ALL=C tr -cd '0-9' < "$heartbeat_file" 2>/dev/null || true)"
  [[ "$stamp" == <-> ]] || { print -r -- "999999"; return 0; }
  now="$(date +%s)"
  print -r -- "$(( now - stamp ))"
}

codex_queue_pending_count() {
  local root="$1"
  local queued_count processing_count
  queued_count="$(find "$root/queued" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d '[:space:]')"
  processing_count="$(find "$root/processing" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d '[:space:]')"
  print -r -- "$(( queued_count + processing_count ))"
}

codex_queue_worker_state() {
  local root="$1"
  local worker="$2"
  local pending_count heartbeat_age
  if ! tmux has-session -t "$worker" 2>/dev/null; then
    print -r -- "worker_stopped"
    return 0
  fi
  pending_count="$(codex_queue_pending_count "$root")"
  heartbeat_age="$(codex_queue_worker_heartbeat_age "$root")"
  if (( pending_count > 0 && heartbeat_age > 45 )); then
    print -r -- "worker_stale"
  else
    print -r -- "worker_running"
  fi
}

codex_queue_worker_start() {
  local root worker command pending_count heartbeat_age
  root="$(codex_queue_root)"
  worker="$(codex_queue_worker_session)"
  codex_queue_prepare_dirs "$root"
  need_tmux
  if tmux has-session -t "$worker" 2>/dev/null; then
    pending_count="$(codex_queue_pending_count "$root")"
    heartbeat_age="$(codex_queue_worker_heartbeat_age "$root")"
    if (( pending_count > 0 && heartbeat_age > 45 )); then
      codex_queue_log "$root" "worker_stale_restart session=$worker age=$heartbeat_age pending=$pending_count"
      tmux kill-session -t "$worker" 2>/dev/null || true
      sleep 0.12
    else
      return 0
    fi
  fi
  rm -f "$(codex_queue_worker_heartbeat_file "$root")" 2>/dev/null || true
  command="A_COCKPIT_CODEX_SESSION=${(q)CODEX_SESSION} A_COCKPIT_SESSION_DIR=${(q)SESSION_DIR} A_COCKPIT_STATE_DIR=${(q)STATE_DIR} A_COCKPIT_CODEX_QUEUE_CONTEXT=1 A_COCKPIT_CODEX_QUEUE_PLUGIN_MODE=${(q)CODEX_QUEUE_PLUGIN_MODE}"
  if [[ -n "$CODEX_BIN" ]]; then
    command="$command A_COCKPIT_CODEX_BIN=${(q)CODEX_BIN}"
  fi
  command="$command ${(q)SCRIPT_PATH} codex-queue-worker"
  tmux new-session -d -s "$worker" -c "$HOME" /bin/zsh -lc "$command"
  codex_queue_touch_worker_heartbeat "$root"
  codex_queue_log "$root" "worker_started session=$worker codex_session=$CODEX_SESSION plugin_mode=$CODEX_QUEUE_PLUGIN_MODE"
}

codex_queue_enqueue() {
  local kind="${1:-send}"
  local model="${2:-}"
  local effort="${3:-}"
  local root tmp_dir job_id job_dir worker prompt_bytes
  case "$kind" in
    send|steer) ;;
    *)
      echo "invalid codex queue kind: $kind" >&2
      exit 66
      ;;
  esac
  if [[ -z "$CODEX_BIN" || ! -x "$CODEX_BIN" ]]; then
    echo "Codex CLI was not found. Expected codex on PATH, Codex.app, or a valid SSHcontroll Codex Path override." >&2
    exit 127
  fi
  if [[ -n "$model" && ! "$model" =~ '^[A-Za-z0-9._-]+$' ]]; then
    echo "invalid codex model: $model" >&2
    exit 66
  fi
  if [[ -n "$effort" ]]; then
    case "$effort" in
      none|minimal|low|medium|high|xhigh) ;;
      *)
        echo "invalid codex reasoning effort: $effort" >&2
        exit 66
        ;;
    esac
  fi

  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  job_id="$(date '+%Y%m%d%H%M%S')-$$-$RANDOM"
  tmp_dir="$root/.tmp-$job_id"
  job_dir="$root/queued/$job_id"
  mkdir -p "$tmp_dir"
  cat > "$tmp_dir/prompt.txt"
  prompt_bytes="$(wc -c < "$tmp_dir/prompt.txt" | tr -d '[:space:]')"
  print -r -- "$kind" > "$tmp_dir/kind"
  if [[ "$kind" == "steer" ]]; then
    : > "$tmp_dir/is-steer"
  fi
  print -r -- "$model" > "$tmp_dir/model"
  print -r -- "$effort" > "$tmp_dir/effort"
  print -r -- "$CODEX_HISTORY_ID" > "$tmp_dir/history_id"
  print -r -- "$(session_start_dir)" > "$tmp_dir/dir"
  print -r -- "$CODEX_SESSION" > "$tmp_dir/codex_session"
  print -r -- "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$tmp_dir/created_at"
  print -r -- "$job_id" > "$tmp_dir/order"
  print -r -- "$prompt_bytes" > "$tmp_dir/prompt_bytes"
  mv "$tmp_dir" "$job_dir"
  worker="$(codex_queue_worker_session)"
  codex_queue_log "$root" "enqueued id=$job_id kind=$kind bytes=$prompt_bytes history=${CODEX_HISTORY_ID:-none} dir=$(session_start_dir)"
  codex_queue_worker_start
  printf 'a_queue_status: queued_on_a\n'
  printf 'a_queue_id: %s\n' "$job_id"
  printf 'a_queue_worker: %s\n' "$worker"
  printf 'a_queue_dir: %s\n' "$root"
}

