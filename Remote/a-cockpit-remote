codex_history_transcript() {
  local session_id path_hint
  session_id="${1:-}"
  path_hint="$(cat 2>/dev/null || true)"
  python3 - "$session_id" "$path_hint" <<'PY'
import json
import pathlib
import re
import sqlite3
import sys

session_id = (sys.argv[1] or "").strip()
path_hint = (sys.argv[2] or "").strip()

def candidate_paths():
    seen = set()
    if path_hint:
        p = pathlib.Path(path_hint).expanduser()
        if p.exists():
            seen.add(str(p))
            yield p
    state_db = pathlib.Path.home() / ".codex" / "state_5.sqlite"
    if session_id and state_db.exists():
        try:
            with sqlite3.connect(str(state_db)) as conn:
                for (rollout_path,) in conn.execute(
                    "select rollout_path from threads where id = ?", (session_id,)
                ):
                    if rollout_path:
                        p = pathlib.Path(rollout_path).expanduser()
                        if p.exists() and str(p) not in seen:
                            seen.add(str(p))
                            yield p
        except Exception:
            pass
    base = pathlib.Path.home() / ".codex" / "sessions"
    if session_id and base.exists():
        for p in base.glob("**/*.jsonl"):
            if session_id in p.name or session_id in str(p):
                if str(p) not in seen:
                    seen.add(str(p))
                    yield p
        for p in base.glob("**/*.jsonl"):
            try:
                with p.open(errors="replace") as handle:
                    for line in handle:
                        try:
                            obj = json.loads(line)
                        except Exception:
                            continue
                        if obj.get("type") == "session_meta":
                            meta = obj.get("payload") or {}
                            if meta.get("id") == session_id and str(p) not in seen:
                                seen.add(str(p))
                                yield p
                            break
            except Exception:
                continue

def text_from_content(content):
    pieces = []
    if isinstance(content, str):
        pieces.append(content)
    elif isinstance(content, list):
        for item in content:
            if isinstance(item, str):
                pieces.append(item)
            elif isinstance(item, dict):
                for key in ("text", "input_text", "output_text", "content", "message"):
                    value = item.get(key)
                    if isinstance(value, str) and value.strip():
                        pieces.append(value)
                        break
                    if isinstance(value, (list, dict)):
                        nested = text_from_content(value)
                        if nested:
                            pieces.append(nested)
                            break
    elif isinstance(content, dict):
        for key in ("text", "input_text", "output_text", "content", "message"):
            value = content.get(key)
            if isinstance(value, str) and value.strip():
                pieces.append(value)
                break
            if isinstance(value, (list, dict)):
                nested = text_from_content(value)
                if nested:
                    pieces.append(nested)
                    break
    return "\n".join(pieces).strip()

def item_text(payload):
    if not isinstance(payload, dict):
        return ""
    for key in ("content", "message", "text", "input", "output"):
        text = text_from_content(payload.get(key))
        if text:
            return text
    return ""

def strip_hidden_prompt_context(text):
    value = str(text or "")
    value = re.sub(r"(?is)<oai-mem-citation>.*?</oai-mem-citation>", "\n", value)
    value = re.sub(r"(?is)<environment_context\b[^>]*>.*?</environment_context>", "\n", value)
    value = re.sub(r"(?is)<(?:subagent_notification|agent_notification)\b[^>]*>.*?</(?:subagent_notification|agent_notification)>", "\n", value)
    value = re.sub(
        r"(?is)<(?:permissions instructions|app-context|collaboration_mode|apps_instructions|skills_instructions|plugins_instructions)\b[^>]*>.*?</(?:permissions instructions|app-context|collaboration_mode|apps_instructions|skills_instructions|plugins_instructions)>",
        "\n",
        value,
    )
    value = re.sub(
        r"(?is)^## Memory\s*$.*?^========= MEMORY_SUMMARY ENDS =========\s*$",
        "\n",
        value,
        flags=re.MULTILINE,
    )
    value = re.sub(r"(?is)When memory is likely relevant, start with the quick memory pass above.*?(?=^›|\Z)", "\n", value, flags=re.MULTILINE)
    value = re.sub(r"(?is)^.*?</collaboration_mode>", "\n", value)
    value = re.sub(r"(?is)#\s*AGENTS\.md instructions[^\n]*\n\s*<INSTRUCTIONS>.*?</INSTRUCTIONS>", "\n", value)
    value = re.sub(r"(?is)<INSTRUCTIONS>.*?</INSTRUCTIONS>", "\n", value)
    value = re.sub(r"(?is)<sshcontroll_attachments>.*?</sshcontroll_attachments>", "\n", value)
    value = re.sub(
        r"(?im)^\s*</?(?:current_date|timezone|shell|cwd|approval_policy|sandbox_mode|environment_context)[^>]*>.*$",
        "",
        value,
    )
    filtered = []
    for raw_line in value.splitlines():
        line = re.sub(r"^\s*[›>•]\s*", "", raw_line)
        comparable = re.sub(r"^\s*\d+\s*:\s*", "", line).strip()
        comparable = re.sub(r"^[-–—]\s*", "", comparable).strip().lower()
        if comparable in {
            "breakdown",
            "breakdown.",
            "analysis",
            "analysis.",
            "reasoning",
            "reasoning.",
            "thinking",
            "thinking.",
            "implement {feature}",
            "find and fix a bug in @filename",
            "improve documentation in @filename",
            "explain this codebase",
            "use /skills to list available skills",
        }:
            continue
        if (
            comparable.startswith("# task group:")
            or comparable.startswith("task group:")
            or comparable.startswith("scope:")
            or comparable.startswith("applies_to:")
            or comparable.startswith("reuse_rule=")
            or "rollout_path=" in comparable
            or "thread_id=" in comparable
            or "chronicle synthetic" in comparable
            or "memory-summary.md" in comparable
            or "memory_summary.md" in comparable
            or "codex/tcc relevant processes" in comparable
            or "apple event error -1743" in comparable
            or "could not create image from display" in comparable
            or comparable.startswith("open-exit=")
            or comparable.startswith("chunk id:")
            or comparable.startswith("wall time:")
            or comparable.startswith("process exited with code")
            or comparable.startswith("process running with session id")
            or comparable.startswith("original token count:")
            or comparable.startswith("queued professor lab:")
            or comparable.startswith("research run: research_loops/")
            or "autonomous research stages are staged on a queue" in comparable
            or re.search(r"\bprofessor-(?:stage|loop)-\d+(?:-of-\d+)?\b", comparable)
            or comparable == "output:"
            or "ktccserviceappleevents" in comparable
            or "png image data," in comparable
            or "host_bundle_capture.png" in comparable
            or "codex cli permission host.app:" in comparable
            or "local.codex.cli-permission-host" in comparable
            or '{"output":' in comparable
            or '"metadata":' in comparable
            or '"exit_code":' in comparable
            or "contents/macos/skycomputeruse" in comparable
            or "contents/resources/codex" in comparable
            or "python.framework/versions/" in comparable
            or re.search(r"^\d+\s+\d+\s+[a-z+]+\s+/", comparable)
        ):
            continue
        filtered.append(raw_line)
    value = "\n".join(filtered)
    value = re.sub(r"\n{3,}", "\n\n", value)
    return value.strip()

def normalize_for_echo(text):
    value = strip_hidden_prompt_context(text)
    value = re.sub(r"^[›>•]\s*", "", value)
    return " ".join(value.split()).strip()

path = next(candidate_paths(), None)
if path is None:
    print(f"Codex history transcript not found for {session_id}", file=sys.stderr)
    sys.exit(66)

rows = []
title = ""
cwd = ""
last_normalized = ""

def append_row(value):
    global last_normalized
    text = str(value or "").strip()
    if not text:
        return
    normalized = normalize_for_echo(text)
    if normalized and normalized == last_normalized:
        return
    rows.append(text)
    last_normalized = normalized

try:
    with path.open(errors="replace") as handle:
        for line in handle:
            try:
                obj = json.loads(line)
            except Exception:
                continue
            typ = obj.get("type") or ""
            payload = obj.get("payload") or {}
            if typ == "session_meta":
                title = payload.get("title") or title
                cwd = payload.get("cwd") or cwd
                continue
            if typ == "response_item":
                item = payload.get("item")
                source = item if isinstance(item, dict) else payload
                role = (source.get("role") or payload.get("role") or "").lower()
                kind = (source.get("type") or payload.get("type") or "").lower()
                text = item_text(source) or item_text(payload)
                if not text:
                    continue
                if role == "user" or kind in ("user_message", "input_text"):
                    clean_text = strip_hidden_prompt_context(text)
                    if clean_text:
                        append_row(f"› {clean_text}")
                elif role == "assistant" or kind in ("assistant_message", "message"):
                    clean_text = strip_hidden_prompt_context(text)
                    if clean_text:
                        append_row(clean_text)
                else:
                    clean_text = strip_hidden_prompt_context(text)
                    if clean_text:
                        append_row(clean_text)
            elif typ == "event_msg":
                message = text_from_content(payload.get("message") or payload)
                if message:
                    clean_message = strip_hidden_prompt_context(message)
                    if clean_message:
                        append_row(f"• {clean_message}")
except Exception as exc:
    print(f"Codex history transcript read failed: {exc}", file=sys.stderr)
    sys.exit(66)

header = []
if title:
    header.append(f"Codex history: {title}")
if cwd:
    header.append(f"directory: {cwd}")
if session_id:
    header.append(f"codex_history_id: {session_id}")
if header:
    print("\n".join(header))
    print("")
print("\n\n".join(rows[-240:]))
PY
}

codex_history_delete() {
  local session_id path_hint
  session_id="${1:-}"
  path_hint="$(cat 2>/dev/null || true)"
  python3 - "$session_id" "$path_hint" <<'PY'
import json
import pathlib
import re
import sqlite3
import sys

session_id = (sys.argv[1] or "").strip()
path_hint = (sys.argv[2] or "").strip()

if not re.match(r"^[0-9a-fA-F-]{12,}$", session_id):
    print("Invalid Codex history id.", file=sys.stderr)
    sys.exit(2)

home = pathlib.Path.home()
state_db = home / ".codex" / "state_5.sqlite"
sessions_base = home / ".codex" / "sessions"

def path_has_session(path):
    if not path.exists() or not path.is_file():
        return False
    if session_id in path.name:
        return True
    try:
        with path.open(errors="replace") as handle:
            for line in handle:
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if obj.get("type") == "session_meta":
                    meta = obj.get("payload") or {}
                    return meta.get("id") == session_id
    except Exception:
        return False
    return False

def add_candidate(path, candidates, seen):
    if not path:
        return
    try:
        resolved = pathlib.Path(path).expanduser()
    except Exception:
        return
    key = str(resolved)
    if key not in seen:
        candidates.append(resolved)
        seen.add(key)

candidates = []
seen = set()
if path_hint:
    add_candidate(path_hint, candidates, seen)

deleted_db_rows = 0
if state_db.exists():
    try:
        with sqlite3.connect(str(state_db)) as conn:
            conn.execute("PRAGMA foreign_keys=ON")
            try:
                row = conn.execute(
                    "select rollout_path from threads where id = ?", (session_id,)
                ).fetchone()
                if row and row[0]:
                    add_candidate(row[0], candidates, seen)
            except Exception:
                pass
            try:
                conn.execute(
                    "delete from thread_spawn_edges where parent_thread_id = ? or child_thread_id = ?",
                    (session_id, session_id),
                )
            except Exception:
                pass
            try:
                conn.execute(
                    "delete from agent_job_items where assigned_thread_id = ?", (session_id,)
                )
            except Exception:
                pass
            cursor = conn.execute("delete from threads where id = ?", (session_id,))
            deleted_db_rows = cursor.rowcount if cursor.rowcount is not None else 0
            conn.commit()
    except Exception as exc:
        print(f"Codex history database delete failed: {exc}", file=sys.stderr)
        sys.exit(66)

if sessions_base.exists():
    for path in sessions_base.glob("**/*.jsonl"):
        if session_id in path.name or session_id in str(path):
            add_candidate(path, candidates, seen)

deleted_files = []
for path in candidates:
    try:
        if path_has_session(path):
            path.unlink()
            deleted_files.append(str(path))
    except Exception as exc:
        print(f"Codex history file delete failed: {exc}", file=sys.stderr)
        sys.exit(66)

print(json.dumps({
    "id": session_id,
    "deleted_db_rows": deleted_db_rows,
    "deleted_files": len(deleted_files),
}, ensure_ascii=False))
PY
}

