               printf('%.0f', total / 1024.0) || 'GB'
        from memory, latest_memory
        where memory.time = latest_memory.t and memory.interval = 5
        limit 1;
      " 2>/dev/null || true
      ;;
    network)
      sqlite3 "$db" "
        with latest_network as (
          select max(time) as t from network where interval = 5
        ),
        active_network as (
          select upload, download
          from network, latest_network
          where network.time = latest_network.t and network.interval = 5
          order by upload + download desc
          limit 1
        )
        select 'Network: up ' ||
               case when upload >= 1024 then printf('%.1f MB/s', upload / 1024.0)
                    else printf('%.1f KB/s', upload) end ||
               ', down ' ||
               case when download >= 1024 then printf('%.1f MB/s', download / 1024.0)
                    else printf('%.1f KB/s', download) end
        from active_network;
      " 2>/dev/null || true
      ;;
    *)
      printf 'unknown monitor metric: %s\n' "$metric" >&2
      return 2
      ;;
  esac
}

