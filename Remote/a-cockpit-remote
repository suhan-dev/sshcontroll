tar_paths() {
  local list_file item_path parent name
  local -a tar_args
  list_file="$(/usr/bin/mktemp "${TMPDIR:-/tmp}/sshcontroll-tar-paths.XXXXXX")" || exit 74
  cat > "$list_file"
  while IFS= read -r item_path; do
    [[ -n "$item_path" ]] || continue
    if [[ "$item_path" == \~ ]]; then
      item_path="$HOME"
    elif [[ "$item_path" == \~/* ]]; then
      item_path="$HOME/${item_path#\~/}"
    elif [[ "$item_path" != /* ]]; then
      item_path="$HOME/$item_path"
    fi
    if [[ ! -e "$item_path" && ! -L "$item_path" ]]; then
      echo "not found: $item_path" >&2
      rm -f -- "$list_file"
      exit 66
    fi
    parent="${item_path:h}"
    name="${item_path:t}"
    if [[ -z "$name" || "$name" == "/" ]]; then
      echo "refusing unsafe archive root: $item_path" >&2
      rm -f -- "$list_file"
      exit 66
    fi
    tar_args+=("-C" "$parent" "$name")
  done < "$list_file"
  rm -f -- "$list_file"
  if (( ${#tar_args} == 0 )); then
    echo "missing path" >&2
    exit 2
  fi
  COPYFILE_DISABLE=1 /usr/bin/tar -cf - "${tar_args[@]}"
}

zip_paths() {
  local list_file
  list_file="$(/usr/bin/mktemp "${TMPDIR:-/tmp}/sshcontroll-zip-paths.XXXXXX")" || exit 74
  cat > "$list_file"
  python3 - "$list_file" <<'PY'
import os
import pathlib
import sys
import zipfile

list_path = pathlib.Path(sys.argv[1])
home = pathlib.Path.home()

def normalize(raw):
    text = str(raw or "").strip()
    if not text:
        return None
    if text == "~":
        return home
    if text.startswith("~/"):
        return home / text[2:]
    path = pathlib.Path(text)
    if not path.is_absolute():
        path = home / path
    return path

raw_paths = list_path.read_text(errors="replace").splitlines()
paths = [path for path in (normalize(raw) for raw in raw_paths) if path is not None]
if not paths:
    print("missing path", file=sys.stderr)
    raise SystemExit(2)

for path in paths:
    if not path.exists() and not path.is_symlink():
        print(f"not found: {path}", file=sys.stderr)
        raise SystemExit(66)

used_roots = {}

def archive_root(path):
    root = path.name or "root"
    count = used_roots.get(root, 0) + 1
    used_roots[root] = count
    if count == 1:
        return root
    stem = pathlib.Path(root).stem or "root"
    suffix = pathlib.Path(root).suffix
    return f"{stem}-{count}{suffix}"

def add_directory(zip_file, root_path, arc_root):
    root_path = pathlib.Path(root_path)
    zip_file.writestr(arc_root.rstrip("/") + "/", b"")
    for current, dirnames, filenames in os.walk(root_path, followlinks=False):
        keep_dirs = []
        for dirname in dirnames:
            full = pathlib.Path(current) / dirname
            try:
                if not full.is_symlink():
                    keep_dirs.append(dirname)
            except OSError:
                pass
        dirnames[:] = keep_dirs

        current_path = pathlib.Path(current)
        rel_dir = current_path.relative_to(root_path)
        if str(rel_dir) != ".":
            zip_file.writestr(f"{arc_root}/{rel_dir.as_posix().rstrip('/')}/", b"")
        for filename in filenames:
            full = current_path / filename
            try:
                if full.is_symlink() or not full.is_file():
                    continue
            except OSError:
                continue
            rel_file = full.relative_to(root_path).as_posix()
            zip_file.write(full, f"{arc_root}/{rel_file}")

with zipfile.ZipFile(
    sys.stdout.buffer,
    "w",
    compression=zipfile.ZIP_DEFLATED,
    compresslevel=1,
    allowZip64=True,
    strict_timestamps=False,
) as zip_file:
    for path in paths:
        arc_root = archive_root(path)
        if path.is_dir():
            add_directory(zip_file, path, arc_root)
        else:
            zip_file.write(path, arc_root)
PY
  local rc=$?
  rm -f -- "$list_file"
  return "$rc"
}

