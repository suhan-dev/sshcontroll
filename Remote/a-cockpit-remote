codex_queue_job_status() {
  local job_id="${1:-}"
  local root state job
  if [[ -z "$job_id" || ! "$job_id" =~ '^[A-Za-z0-9_.-]+$' ]]; then
    echo "invalid a_queue_id: $job_id" >&2
    exit 66
  fi
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  for state in queued processing done failed; do
    job="$root/$state/$job_id"
    if [[ -d "$job" ]]; then
      printf 'a_queue_item_status: %s\n' "$state"
      printf 'a_queue_id: %s\n' "$job_id"
      if [[ -s "$job/history_id" ]]; then
        printf 'a_queue_history_id: %s\n' "$(cat "$job/history_id" | head -1)"
      fi
      if [[ -s "$job/worker.log" ]]; then
        printf 'a_queue_worker_log_tail: %s\n' "$(tail -n 4 "$job/worker.log" | tr '\n' ' ' | sed 's/[[:space:]]\\{1,\\}/ /g')"
      fi
      return 0
    fi
  done
  printf 'a_queue_item_status: not_found\n'
  printf 'a_queue_id: %s\n' "$job_id"
  exit 67
}

codex_queue_recent() {
  local limit="${1:-12}" root
  root="$(codex_queue_root)"
  codex_queue_prepare_dirs "$root"
  python3 - "$root" "$limit" <<'PY'
import json
import os
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
try:
    limit = max(1, min(int(sys.argv[2] or "12"), 50))
except Exception:
    limit = 12

def read_text(path):
    try:
        return path.read_text(errors="replace").strip()
    except Exception:
        return ""

def prompt_title(value):
    lines = [line.strip() for line in value.splitlines() if line.strip()]
    title = lines[0] if lines else ""
    title = " ".join(title.split())
    if len(title) > 220:
        title = title[:217] + "..."
    return title

items = []
for status in ("queued", "processing", "done", "failed"):
    directory = root / status
    if not directory.exists():
        continue
    for job in directory.iterdir():
        if not job.is_dir():
            continue
        prompt = read_text(job / "prompt.txt")
        try:
            mtime = job.stat().st_mtime
        except Exception:
            mtime = 0
        items.append({
            "id": job.name,
            "status": status,
            "kind": read_text(job / "kind") or "send",
            "prompt": prompt_title(prompt),
            "directory": read_text(job / "dir"),
            "historyID": read_text(job / "history_id"),
            "codexSession": read_text(job / "codex_session"),
            "createdAt": read_text(job / "created_at"),
            "sentAt": read_text(job / "sent_at"),
            "promptBytes": int(read_text(job / "prompt_bytes") or "0"),
            "mtime": mtime,
        })

status_rank = {"queued": 0, "processing": 1, "done": 2, "failed": 3}
items.sort(key=lambda item: (status_rank.get(item["status"], 9), -item["mtime"]))
print(json.dumps({"items": items[:limit]}, ensure_ascii=False, separators=(",", ":")))
PY
}

