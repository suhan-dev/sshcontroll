  if ! mfc_is_installed; then
    mfc_not_installed_message >&2
    return 66
  fi
  open -gja "Macs Fan Control" >/dev/null 2>&1 || open -ga "Macs Fan Control" >/dev/null 2>&1
  sleep 1.5
  mfc_hide_quietly
}

mfc_custom_index_for_name() {
  local wanted="$1"
  /usr/bin/python3 - "$wanted" <<'PY' 2>/dev/null || true
import base64
import re
import subprocess
import sys

wanted = sys.argv[1]
proc = subprocess.run(
    ["/usr/bin/defaults", "read", "com.crystalidea.macsfancontrol", "CustomPresets"],
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
)
if proc.returncode != 0:
    raise SystemExit(0)
values = []
for quoted, bare in re.findall(r'"([^"]+)"|([A-Za-z0-9+/=]{8,})', proc.stdout):
    value = quoted or bare
    if value and value not in values:
        values.append(value)
for index, value in enumerate(values):
    try:
