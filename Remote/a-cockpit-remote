list_dir_tree() {
  local dir depth
  dir="$(read_path_arg)"
  depth="${1:-2}"
  if [[ ! -d "$dir" ]]; then
    echo "not a directory: $dir" >&2
    exit 66
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for list-dir-tree JSON output" >&2
    exit 127
  fi
  python3 - "$dir" "$depth" <<'PY'
import json
import os
import sys

root = os.path.abspath(os.path.expanduser(sys.argv[1]))
try:
    max_depth = max(1, min(int(sys.argv[2] or "2"), 4))
except Exception:
    max_depth = 2
max_dirs = 512
result = {}
visited = 0

def scan(directory):
    items = []
    try:
        entries = list(os.scandir(directory))
    except OSError:
        return items
    for entry in entries:
        try:
            st = entry.stat(follow_symlinks=False)
            is_dir = entry.is_dir(follow_symlinks=False)
            is_link = entry.is_symlink()
            if is_link:
                try:
                    is_dir = entry.is_dir(follow_symlinks=True)
                except OSError:
                    pass
            items.append({
                "name": entry.name,
                "path": os.path.join(directory, entry.name),
                "type": "dir" if is_dir else "file",
                "size": st.st_size,
                "mtime": int(st.st_mtime),
                "symlink": is_link,
            })
        except OSError:
            items.append({
                "name": entry.name,
                "path": os.path.join(directory, entry.name),
                "type": "file",
                "size": 0,
                "mtime": 0,
                "symlink": entry.is_symlink(),
            })
    items.sort(key=lambda item: (item["name"].startswith("."), item["type"] != "dir", item["name"].lower()))
    return items

def walk(directory, depth):
    global visited
    if visited >= max_dirs or depth < 0:
        return
    items = scan(directory)
    result[directory] = items
    visited += 1
    if depth == 0:
        return
    for item in items:
        if visited >= max_dirs:
            return
        if item["type"] != "dir":
            continue
        name = item["name"]
        if name in {
            ".git",
            ".dart_tool",
            ".gradle",
            ".mypy_cache",
            ".pytest_cache",
            ".tox",
            ".venv",
            ".swiftpm",
            "DerivedData",
            "Pods",
            "node_modules",
            "build",
            "__pycache__",
            "venv",
        }:
            continue
        if name.startswith(".") and depth <= 1:
            continue
        walk(item["path"], depth - 1)

walk(root, max_depth)
print(json.dumps(result, ensure_ascii=False, separators=(",", ":")))
PY
}

read_path_arg() {
