                title = good_title(obj.get("thread_name") or "")
                if title:
                    index_titles[session_id] = title
                parsed_time = parse_index_time(obj.get("updated_at"))
                if parsed_time:
                    index_times[session_id] = max(index_times.get(session_id, 0), parsed_time)
    except Exception:
        pass

if state_db.exists():
    try:
        with sqlite3.connect(str(state_db)) as conn:
            for session_id, cwd, title, rollout_path, source, thread_source, agent_role in conn.execute(
                "select id, cwd, title, rollout_path, source, coalesce(thread_source,''), coalesce(agent_role,'') from threads"
            ):
                if not session_id:
                    continue
                source = str(source or "")
                thread_source = str(thread_source or "")
                agent_role = str(agent_role or "")
